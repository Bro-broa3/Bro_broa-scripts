local ThemeListCorner=Instance.new("UICorner"); ThemeListCorner.CornerRadius=UDim.new(0,5); ThemeListCorner.Parent=ThemeList

local themeNames={"Default","Dark Blue","Light","Neon Light","Dark Light","Bright","Blue"}
for i,n in ipairs(themeNames) do
    local b=Instance.new("TextButton"); b.Size=UDim2.new(1,-10,0,28); b.Position=UDim2.new(0,5,0,(i-1)*30+3); b.BackgroundColor3=Color3.fromRGB(55,55,63); b.BorderSizePixel=0; b.Text=n; b.TextColor3=Color3.fromRGB(255,255,255); b.Font=Enum.Font.Gotham; b.TextSize=12; b.Parent=ThemeList
    local bc=Instance.new("UICorner"); bc.CornerRadius=UDim.new(0,4); bc.Parent=b; b.MouseButton1Click:Connect(function() applyTheme(n); ThemeDropdown.Text=n.." ▼"; ThemeList.Visible=false end)
end
ThemeList.CanvasSize=UDim2.new(0,0,0,#themeNames*30+6); ThemeDropdown.MouseButton1Click:Connect(function() ThemeList.Visible=not ThemeList.Visible end)

local SaveThemeLabel=Instance.new("TextLabel"); SaveThemeLabel.Size=UDim2.new(0,200,0,25); SaveThemeLabel.Position=UDim2.new(0,15,0,170); SaveThemeLabel.BackgroundTransparency=1; SaveThemeLabel.Text="Save Theme Config:"; SaveThemeLabel.TextColor3=Color3.fromRGB(220,220,230); SaveThemeLabel.TextXAlignment=Enum.TextXAlignment.Left; SaveThemeLabel.Font=Enum.Font.GothamBold; SaveThemeLabel.TextSize=13; SaveThemeLabel.Parent=SettingsPanel
local SaveThemeToggle=Instance.new("TextButton"); SaveThemeToggle.Size=UDim2.new(0,60,0,28); SaveThemeToggle.Position=UDim2.new(0,220,0,168); SaveThemeToggle.BorderSizePixel=0; SaveThemeToggle.Font=Enum.Font.GothamBold; SaveThemeToggle.TextSize=12; SaveThemeToggle.TextColor3=Color3.fromRGB(255,255,255); SaveThemeToggle.Parent=SettingsPanel
local SaveThemeToggleCorner=Instance.new("UICorner"); SaveThemeToggleCorner.CornerRadius=UDim.new(0,6); SaveThemeToggleCorner.Parent=SaveThemeToggle
local function updateSaveThemeToggle() if saveThemeEnabled then SaveThemeToggle.BackgroundColor3=Color3.fromRGB(80,180,80); SaveThemeToggle.Text="ON" else SaveThemeToggle.BackgroundColor3=Color3.fromRGB(180,80,80); SaveThemeToggle.Text="OFF" end end
SaveThemeToggle.MouseButton1Click:Connect(function() saveThemeEnabled=not saveThemeEnabled; updateSaveThemeToggle(); if saveThemeEnabled then saveSettings() else pcall(function() if isfile and isfile(SETTINGS_FILE) then delfile(SETTINGS_FILE) end end) end end)

local MiniPlayLabel=Instance.new("TextLabel"); MiniPlayLabel.Size=UDim2.new(0,200,0,25); MiniPlayLabel.Position=UDim2.new(0,15,0,210); MiniPlayLabel.BackgroundTransparency=1; MiniPlayLabel.Text="Mini Play Mode:"; MiniPlayLabel.TextColor3=Color3.fromRGB(220,220,230); MiniPlayLabel.TextXAlignment=Enum.TextXAlignment.Left; MiniPlayLabel.Font=Enum.Font.GothamBold; MiniPlayLabel.TextSize=13; MiniPlayLabel.Parent=SettingsPanel
