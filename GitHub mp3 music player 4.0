local MiniPlayToggleCorner=Instance.new("UICorner"); MiniPlayToggleCorner.CornerRadius=UDim.new(0,6); MiniPlayToggleCorner.Parent=MiniPlayToggle
local function updateMiniPlayToggle() MiniPlayToggle.BackgroundColor3=miniPlayMode and Color3.fromRGB(80,180,80) or Color3.fromRGB(180,80,80); MiniPlayToggle.Text=miniPlayMode and "ON" or "OFF" end

