-- ========== CREATE FOLDER STRUCTURE ==========
local MUSIC_FOLDER = "MusicPlayerData"
local CACHE_FOLDER = MUSIC_FOLDER .. "/Cache"
pcall(function() if makefolder then makefolder(MUSIC_FOLDER) end end)
pcall(function() if makefolder then makefolder(CACHE_FOLDER) end end)

local HISTORY_FILE = MUSIC_FOLDER .. "/mp3_history.json"
local CACHE_FILE = MUSIC_FOLDER .. "/mp3_cache.json"
local SETTINGS_FILE = MUSIC_FOLDER .. "/mp3_settings.json"

-- ========== CHECK FOR EXISTING GUI AND STOP MUSIC ==========
local existingGui = CoreGui:FindFirstChild("MusicPlayerGUI")
if existingGui then
    pcall(function()
        local sounds = workspace:GetDescendants()
        for _, sound in pairs(sounds) do
            if sound:IsA("Sound") and sound.Name == "MusicPlayerSound" then
                sound:Stop()
                sound:Destroy()
            end
        end
    end)
    existingGui:Destroy()
end
local existingMini = CoreGui:FindFirstChild("MusicPlayerMiniGUI")
if existingMini then
    existingMini:Destroy()
end

