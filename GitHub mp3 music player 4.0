-- ========== SETTINGS SAVE/LOAD ==========
local function loadSettings()
    local s, r = pcall(function() if readfile and isfile and isfile(SETTINGS_FILE) then return HttpService:JSONDecode(readfile(SETTINGS_FILE)) end end)
    if s and r then if r.theme then currentTheme = r.theme end; if r.saveThemeEnabled ~= nil then saveThemeEnabled = r.saveThemeEnabled end end
end
local function saveSettings()
    if not saveThemeEnabled then return end
    pcall(function() if writefile then writefile(SETTINGS_FILE, HttpService:JSONEncode({theme = currentTheme, saveThemeEnabled = saveThemeEnabled})) end end)
end

-- ========== CLEAN SONG NAME ==========
local function cleanSongName(fn)
    if not fn then return "Unknown" end
    fn = string.gsub(fn, "%.mp3$", ""); fn = string.gsub(fn, "%.MP3$", ""); fn = string.gsub(fn, "%%20", " ")
    return fn
end

-- ========== APPLY THEME ==========
local function applyTheme(tn)
    local t = themes[tn] or themes["Default"]; currentTheme = tn
    MainFrame.BackgroundColor3 = t.mainBg; OutlineFrame.BackgroundColor3 = t.mainBg
    TitleBar.BackgroundColor3 = t.titleBg; UIStroke.Color = t.outlineColor
    ContentFrame.BackgroundTransparency = 1; UrlContainer.BackgroundColor3 = t.inputBg
    UrlLabel.TextColor3 = t.labelColor
    PlayButton.BackgroundColor3 = t.playColor; PauseButton.BackgroundColor3 = t.pauseColor
    StopButton.BackgroundColor3 = t.stopColor; HistoryButton.BackgroundColor3 = t.historyColor
    MuteToggle.BackgroundColor3 = isGameMuted and t.muteOnColor or t.muteColor
    LoopToggle.BackgroundColor3 = t.loopColor; SearchButton.BackgroundColor3 = t.searchColor
    InfoButton.BackgroundColor3 = t.infoColor; SettingsButton.BackgroundColor3 = t.settingColor
    ToggleSettingsButton.BackgroundColor3 = t.settingColor
    VolumeFill.BackgroundColor3 = t.volumeFill; VolumeSlider.BackgroundColor3 = t.inputBg
    VolumeLabel.TextColor3 = t.labelColor; SpeedTextBox.BackgroundColor3 = t.inputBg
    SpeedTextBox.TextColor3 = t.textColor; SpeedLabel.TextColor3 = t.labelColor
    SpeedDownButton.BackgroundColor3 = t.speedBtnColor; SpeedUpButton.BackgroundColor3 = t.speedBtnColor
    TimeSlider.BackgroundColor3 = t.timeSlider; TimeSliderBg.BackgroundColor3 = t.inputBg
    StatusLabel.TextColor3 = t.textColor; TitleText.TextColor3 = t.textColor
    UrlTextBox.TextColor3 = t.textColor
    local w = Color3.fromRGB(255,255,255)
    for _, b in pairs({PlayButton,PauseButton,StopButton,HistoryButton,MuteToggle,LoopToggle,SearchButton,InfoButton,SettingsButton,ToggleSettingsButton}) do b.TextColor3 = w end
    if SearchPanelStroke then SearchPanelStroke.Color = t.searchColor end
    if InfoPanelStroke then InfoPanelStroke.Color = t.infoColor end
    if MiniFrame then
        MiniFrame.BackgroundColor3 = t.mainBg; MiniOutlineFrame.BackgroundColor3 = t.mainBg
        MiniUIStroke.Color = t.outlineColor; MiniTimeSliderBg.BackgroundColor3 = t.inputBg
        MiniTimeSlider.BackgroundColor3 = t.timeSlider; MiniTimeLabel.TextColor3 = t.textColor
        MiniSongLabel.TextColor3 = t.textColor
        for _, b in pairs({MiniPauseButton,MiniRewindButton,MiniForwardButton,MiniShowButton}) do b.BackgroundColor3 = t.miniBtnColor; b.TextColor3 = w end
    end
    saveSettings()
end

-- ========== FORMAT TIME ==========
local function formatTime(s)
    if s < 0 then s = 0 end
    return string.format("%d:%02d", math.floor(s/60), math.floor(s%60))
end

local rainbowColors = {
    Color3.fromRGB(255,50,50),Color3.fromRGB(255,150,50),Color3.fromRGB(255,255,50),
    Color3.fromRGB(50,255,50),Color3.fromRGB(50,150,255),Color3.fromRGB(150,50,255),Color3.fromRGB(255,50,255)
}

-- CRITICAL FIX: updateTimeDisplay now always updates the slider position from currentSound.TimePosition
local function updateTimeDisplay()
    if not currentSound then
        if TimeLabel then TimeLabel.Text = "0:00 / 0:00"; TimeLabel.TextColor3 = Color3.fromRGB(200,200,200) end
        if TimeSlider then TimeSlider.Size = UDim2.new(0,0,1,0) end
        if MiniTimeLabel then MiniTimeLabel.Text = "0:00 / 0:00" end
        if MiniTimeSlider then MiniTimeSlider.Size = UDim2.new(0,0,1,0) end
        return
    end
    
    local tp = currentSound.TimePosition
    local tl = currentSound.TimeLength
    if tp ~= tp then tp = 0 end
    if tl ~= tl or tl <= 0 then tl = 1 end
    
    local timeText = formatTime(tp) .. " / " .. formatTime(tl)
    
    if TimeLabel then
        TimeLabel.Text = currentSongName ~= "" and (timeText .. "   " .. currentSongName) or timeText
    end
    
    -- Always update slider from actual sound position (not just when not dragging)
    local frac = math.clamp(tp / tl, 0, 1)
    if TimeSlider then TimeSlider.Size = UDim2.new(frac, 0, 1, 0) end
    if MiniTimeLabel then MiniTimeLabel.Text = timeText end
    if MiniTimeSlider then MiniTimeSlider.Size = UDim2.new(frac, 0, 1, 0) end
    if MiniSongLabel and currentSongName ~= "" then MiniSongLabel.Text = currentSongName end
    if MiniPauseButton then MiniPauseButton.Text = isPaused and "▶" or "⏸" end
end

local function animateTimeLabelColor()
    local ci = 1
    while TimeLabel and TimeLabel.Parent do
        if currentSongName ~= "" then
            local c = rainbowColors[ci]
            TweenService:Create(TimeLabel, TweenInfo.new(0.5), {TextColor3 = c}):Play()
            if MiniSongLabel then TweenService:Create(MiniSongLabel, TweenInfo.new(0.5), {TextColor3 = c}):Play() end
            ci = ci + 1; if ci > #rainbowColors then ci = 1 end
        end
        wait(0.5)
    end
end

-- ========== CORE FUNCTIONS ==========
local function loadCache()
    local s,r = pcall(function() if readfile and isfile and isfile(CACHE_FILE) then return HttpService:JSONDecode(readfile(CACHE_FILE)) end end)
    return s and r or {}
end
local function saveCache() pcall(function() if writefile then writefile(CACHE_FILE, HttpService:JSONEncode(musicCache)) end end) end
local function cleanOldCache()
    pcall(function()
        if listfiles then
            local fl = listfiles(CACHE_FOLDER); local cf = {}
            for _, f in ipairs(fl) do if string.find(f,"cache_") and string.find(f,".mp3") then table.insert(cf, CACHE_FOLDER.."/"..f) end end
            table.sort(cf, function(a,b) return a>b end)
            for i=21,#cf do pcall(function() delfile(cf[i]) end) end
        end
    end)
end
local function loadHistory()
    local s,r = pcall(function() if readfile and isfile and isfile(HISTORY_FILE) then return HttpService:JSONDecode(readfile(HISTORY_FILE)) end end)
    return s and r or {}
end
local function saveHistory() pcall(function() if writefile then writefile(HISTORY_FILE, HttpService:JSONEncode(downloadHistory)) end end) end
local function addToHistory(url, fn)
    for i,e in ipairs(downloadHistory) do if e.url==url then table.remove(downloadHistory,i); break end end
    table.insert(downloadHistory,1,{url=url,fileName=fn,timestamp=os.time(),date=os.date("%Y-%m-%d %H:%M:%S")})
    if #downloadHistory>50 then for i=51,#downloadHistory do downloadHistory[i]=nil end end
    saveHistory()
end
local function removeFromHistory(idx)
    if downloadHistory[idx] then table.remove(downloadHistory,idx); saveHistory(); return true end
    return false
end
local function stopMusic()
    if currentSound then currentSound:Stop(); currentSound:Destroy(); currentSound=nil end
    isPlaying=false; isPaused=false; pausedTimePosition=0; currentSongName=""
    updateTimeDisplay()
end

local function muteAllGameSounds(mute)
    isGameMuted=mute
    pcall(function() SoundService.RespectFilteringEnabled=false; if mute then originalSoundServiceMuted=SoundService.Muted; SoundService.Muted=true else SoundService.Muted=originalSoundServiceMuted end end)
    local svcs={game,workspace,game:GetService("Lighting"),game:GetService("ReplicatedStorage"),game:GetService("ReplicatedFirst"),game:GetService("ServerStorage"),game:GetService("ServerScriptService"),game:GetService("StarterGui"),game:GetService("StarterPack"),game:GetService("StarterPlayer"),game:GetService("StarterCharacterScripts"),game:GetService("SoundService"),game:GetService("Players"),game:GetService("Chat"),game:GetService("TeleportService")}
    if player then if player.Character then table.insert(svcs,player.Character) end; if player.Backpack then table.insert(svcs,player.Backpack) end; if player.PlayerGui then table.insert(svcs,player.PlayerGui) end; if player.PlayerScripts then table.insert(svcs,player.PlayerScripts) end end
    pcall(function() if workspace.CurrentCamera then table.insert(svcs,workspace.CurrentCamera) end end)
    for _,c in ipairs(svcs) do pcall(function() if c then for _,o in pairs(c:GetDescendants()) do if o==currentSound then elseif o:IsA("Sound") then if mute then if originalSoundVolumes[o]==nil then originalSoundVolumes[o]=o.Volume end; o.Volume=0 else local ov=originalSoundVolumes[o]; if ov~=nil then o.Volume=ov; originalSoundVolumes[o]=nil end end elseif o:IsA("SoundGroup") then if mute then if originalSoundGroupVolumes[o]==nil then originalSoundGroupVolumes[o]=o.Volume end; o.Volume=0 else local ov=originalSoundGroupVolumes[o]; if ov~=nil then o.Volume=ov; originalSoundGroupVolumes[o]=nil end end end end end end) end
    if currentSound then pcall(function() currentSound.Volume=currentVolume end) end
    if not mute then originalSoundVolumes={}; originalSoundGroupVolumes={} end
    if MuteToggle then local t=themes[currentTheme] or themes["Default"]; MuteToggle.BackgroundColor3=mute and t.muteOnColor or t.muteColor; MuteToggle.Text=mute and "🔇 MUTE: ON" or "🔊 MUTE: OFF" end
end

local function updateVolumeSlider(v)
    currentVolume=v; if VolumeFill then VolumeFill.Size=UDim2.new(v,0,1,0) end
    if VolumeLabel then VolumeLabel.Text="Volume: "..math.floor(v*100).."%" end
    if currentSound then currentSound.Volume=v end
end
local function updateSpeed(s)
    currentSpeed=s; if SpeedTextBox then SpeedTextBox.Text=string.format("%.2f",s).."x" end
    if SpeedLabel then SpeedLabel.Text="Speed: "..string.format("%.2f",s).."x" end
    if currentSound then currentSound.PlaybackSpeed=s end
end

local function togglePause()
    if not currentSound then return end
    if isPaused then
        currentSound.TimePosition = pausedTimePosition
        currentSound:Resume()
        isPaused = false; isPlaying = true
        if PauseButton then PauseButton.Text = "⏸ PAUSE" end
    else
        pausedTimePosition = currentSound.TimePosition
        currentSound:Pause()
        isPaused = true; isPlaying = false
        if PauseButton then PauseButton.Text = "▶ RESUME" end
    end
    -- Force update display immediately after pause toggle
    updateTimeDisplay()
end

local function playMusicFromUrl(url, fn)
    stopMusic(); currentSongName = cleanSongName(fn)
    if StatusLabel then StatusLabel.Text="⏬ Loading..."; StatusLabel.TextColor3=Color3.fromRGB(255,200,100) end
    if MiniSongLabel then MiniSongLabel.Text=currentSongName end
    if musicCache[url] and musicCache[url].fileName then
        local cf=musicCache[url].fileName
        if isfile and isfile(cf) then
            if StatusLabel then StatusLabel.Text="📦 Using cached file..."; StatusLabel.TextColor3=Color3.fromRGB(100,200,255) end
            currentSound=Instance.new("Sound"); currentSound.Name="MusicPlayerSound"
            currentSound.SoundId=getcustomasset(cf); currentSound.Volume=currentVolume
            currentSound.Looped=isLooping; currentSound.PlaybackSpeed=currentSpeed; currentSound.Parent=workspace
            currentSound:Play(); isPlaying=true; isPaused=false; pausedTimePosition=0
            if PauseButton then PauseButton.Text="⏸ PAUSE" end
            if StatusLabel then StatusLabel.Text="🎵 Now Playing: "..currentSongName; StatusLabel.TextColor3=Color3.fromRGB(100,255,100) end
            addToHistory(url,fn); updateTimeDisplay(); return true
        else musicCache[url]=nil; saveCache() end
    end
    if StatusLabel then StatusLabel.Text="⏬ Downloading..."; StatusLabel.TextColor3=Color3.fromRGB(255,200,100) end
    local ts=os.time(); local cfn=CACHE_FOLDER.."/cache_"..ts..".mp3"
    local s,err=pcall(function()
        local d=game:HttpGet(url); writefile(cfn,d); musicCache[url]={fileName=cfn,timestamp=ts}; saveCache()
        currentSound=Instance.new("Sound"); currentSound.Name="MusicPlayerSound"
        currentSound.SoundId=getcustomasset(cfn); currentSound.Volume=currentVolume
        currentSound.Looped=isLooping; currentSound.PlaybackSpeed=currentSpeed; currentSound.Parent=workspace
        currentSound:Play(); isPlaying=true; isPaused=false; pausedTimePosition=0
        if PauseButton then PauseButton.Text="⏸ PAUSE" end
    end)
    if s and currentSound then
        if StatusLabel then StatusLabel.Text="🎵 Now Playing: "..currentSongName; StatusLabel.TextColor3=Color3.fromRGB(100,255,100) end
        addToHistory(url,fn); cleanOldCache(); updateTimeDisplay(); return true
    else
        if StatusLabel then StatusLabel.Text="❌ Error: "..tostring(err); StatusLabel.TextColor3=Color3.fromRGB(255,100,100) end
        currentSongName=""; stopMusic(); return false
    end
end

