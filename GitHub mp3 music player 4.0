MiniPauseButton.MouseButton1Click:Connect(function() if not currentSound then return end; togglePause() end)
MiniRewindButton.MouseButton1Click:Connect(function() if not currentSound then return end; local nt=math.max(currentSound.TimePosition-10,0); currentSound.TimePosition=nt; if isPaused then pausedTimePosition=nt end; updateTimeDisplay() end)
MiniForwardButton.MouseButton1Click:Connect(function() if not currentSound then return end; local nt=math.min(currentSound.TimePosition+10,currentSound.TimeLength); currentSound.TimePosition=nt; if isPaused then pausedTimePosition=nt end; updateTimeDisplay() end)

local function toggleMiniPlayMode()
    miniPlayMode=not miniPlayMode; updateMiniPlayToggle()
    if miniPlayMode then ScreenGui.Enabled=false; MiniScreenGui.Enabled=true; if isSearchOpen then isSearchOpen=false; SearchPanel.Visible=false end; if isInfoOpen then isInfoOpen=false; InfoPanel.Visible=false end; if isSettingsOpen then isSettingsOpen=false; SettingsPanel.Visible=false end
    else ScreenGui.Enabled=true; MiniScreenGui.Enabled=false end
end
MiniPlayToggle.MouseButton1Click:Connect(toggleMiniPlayMode)
MiniShowButton.MouseButton1Click:Connect(function() toggleMiniPlayMode() end)

-- ========== TIME SLIDER EVENTS (FIXED) ==========
-- Main time slider
TimeSliderButton.MouseButton1Down:Connect(function()
    isDraggingTimeSlider = true
    if currentSound and currentSound.TimeLength > 0 then
        local mx = mouse.X - TimeSliderBg.AbsolutePosition.X
        local frac = math.clamp(mx / TimeSliderBg.AbsoluteSize.X, 0, 1)
        local nt = frac * currentSound.TimeLength
        currentSound.TimePosition = nt
        if isPaused then pausedTimePosition = nt end
        updateTimeDisplay()
    end
end)

-- Mini time slider
MiniTimeSliderButton.MouseButton1Down:Connect(function()
    isDraggingMiniTimeSlider = true
    if currentSound and currentSound.TimeLength > 0 then
        local mx = mouse.X - MiniTimeSliderBg.AbsolutePosition.X
        local frac = math.clamp(mx / MiniTimeSliderBg.AbsoluteSize.X, 0, 1)
        local nt = frac * currentSound.TimeLength
        currentSound.TimePosition = nt
        if isPaused then pausedTimePosition = nt end
        updateTimeDisplay()
    end
end)

-- Global mouse movement for continuous dragging
UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        if isDraggingTimeSlider and currentSound and currentSound.TimeLength > 0 then
            local mx = mouse.X - TimeSliderBg.AbsolutePosition.X
            local frac = math.clamp(mx / TimeSliderBg.AbsoluteSize.X, 0, 1)
            local nt = frac * currentSound.TimeLength
            currentSound.TimePosition = nt
            if isPaused then pausedTimePosition = nt end
            updateTimeDisplay()
        elseif isDraggingMiniTimeSlider and currentSound and currentSound.TimeLength > 0 then
            local mx = mouse.X - MiniTimeSliderBg.AbsolutePosition.X
            local frac = math.clamp(mx / MiniTimeSliderBg.AbsoluteSize.X, 0, 1)
            local nt = frac * currentSound.TimeLength
            currentSound.TimePosition = nt
            if isPaused then pausedTimePosition = nt end
            updateTimeDisplay()
        end
    end
end)

-- Global mouse release
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDraggingTimeSlider = false
        isDraggingMiniTimeSlider = false
    end
end)

-- ========== FUNCTIONS ==========
local function applySpeedFromTextBox()
    local t=string.gsub(string.gsub(SpeedTextBox.Text,"x",""),"X",""); local s=tonumber(t)
    if s then updateSpeed(math.clamp(s,0,100)) else SpeedTextBox.Text=string.format("%.2f",currentSpeed).."x" end
end

local function searchMusic(st)
    if not SearchScrollFrame then return end
    for _,c in pairs(SearchScrollFrame:GetChildren()) do if c.Name=="SearchResultItem" then c:Destroy() end end
    if st=="" then if SearchNoResultsLabel then SearchNoResultsLabel.Visible=true; SearchNoResultsLabel.Text="🔍 Enter a search term or URL" end; SearchScrollFrame.CanvasSize=UDim2.new(0,0,0,0); return end
    SearchNoResultsLabel.Visible=false
    local isFU=string.find(st,"http") and string.find(st,".mp3")
    if isFU then
        local s,r=pcall(function() return game:HttpGet(st) end)
        if s and r and #r>0 then
            local fn="audio.mp3"; local pts=string.split(st,"/")
            if #pts>0 and string.find(pts[#pts],".mp3") then fn=string.gsub(string.gsub(pts[#pts],"%%20"," "),"%%25","%%") end
            local it=Instance.new("Frame"); it.Name="SearchResultItem"; it.Size=UDim2.new(1,-10,0,50); it.Position=UDim2.new(0,5,0,0); it.BackgroundColor3=Color3.fromRGB(50,50,60); it.BorderSizePixel=0; it.Parent=SearchScrollFrame
            local ic=Instance.new("UICorner"); ic.CornerRadius=UDim.new(0,4); ic.Parent=it
            local lb=Instance.new("TextLabel"); lb.Size=UDim2.new(1,-70,0,20); lb.Position=UDim2.new(0,5,0,5); lb.BackgroundTransparency=1; lb.Text=fn; lb.TextColor3=Color3.fromRGB(255,255,255); lb.Font=Enum.Font.GothamBold; lb.TextSize=12; lb.Parent=it
            local pb=Instance.new("TextButton"); pb.Size=UDim2.new(0,60,0,30); pb.Position=UDim2.new(1,-65,0,10); pb.BackgroundColor3=Color3.fromRGB(70,150,70); pb.BorderSizePixel=0; pb.Text="PLAY"; pb.TextColor3=Color3.fromRGB(255,255,255); pb.Font=Enum.Font.GothamBold; pb.TextSize=10; pb.Parent=it
            local pbc=Instance.new("UICorner"); pbc.CornerRadius=UDim.new(0,4); pbc.Parent=pb
            pb.MouseButton1Click:Connect(function() if isSearchOpen then toggleSearchPanel() end; playMusicFromUrl(st,fn) end)
            SearchScrollFrame.CanvasSize=UDim2.new(0,0,0,60)
        else SearchNoResultsLabel.Visible=true; SearchNoResultsLabel.Text="❌ URL not found"; SearchScrollFrame.CanvasSize=UDim2.new(0,0,0,0) end
    else
        local fd={}
        pcall(function()
            local bu="https://github.com/Bro-broa3/PrimeMusic/raw/main/"
            local tr={string.gsub(st," ","%%20")..".mp3",string.gsub(string.lower(st)," ","%%20")..".mp3",string.gsub(st," ","")..".mp3",string.gsub(string.lower(st)," ","_")..".mp3",string.gsub(string.lower(st)," ","-")..".mp3",string.lower(string.gsub(st," ",""))..".mp3"}
            for _,fn in ipairs(tr) do pcall(function() local rp=game:HttpGet(bu..fn); if rp and #rp>1000 then table.insert(fd,{url=bu..fn,fileName=string.gsub(fn,"%%20"," ")}) end end) end
        end)
        if #fd>0 then
            local th=0
            for _,rs in ipairs(fd) do
                local it=Instance.new("Frame"); it.Name="SearchResultItem"; it.Size=UDim2.new(1,-10,0,50); it.Position=UDim2.new(0,5,0,th); it.BackgroundColor3=Color3.fromRGB(50,50,60); it.BorderSizePixel=0; it.Parent=SearchScrollFrame
                local ic=Instance.new("UICorner"); ic.CornerRadius=UDim.new(0,4); ic.Parent=it
                local lb=Instance.new("TextLabel"); lb.Size=UDim2.new(1,-70,0,20); lb.Position=UDim2.new(0,5,0,5); lb.BackgroundTransparency=1; lb.Text=rs.fileName; lb.TextColor3=Color3.fromRGB(255,255,255); lb.Font=Enum.Font.GothamBold; lb.TextSize=12; lb.Parent=it
                local pb=Instance.new("TextButton"); pb.Size=UDim2.new(0,60,0,30); pb.Position=UDim2.new(1,-65,0,10); pb.BackgroundColor3=Color3.fromRGB(70,150,70); pb.BorderSizePixel=0; pb.Text="PLAY"; pb.TextColor3=Color3.fromRGB(255,255,255); pb.Font=Enum.Font.GothamBold; pb.TextSize=10; pb.Parent=it
                local pbc=Instance.new("UICorner"); pbc.CornerRadius=UDim.new(0,4); pbc.Parent=pb
                local ru,rf=rs.url,rs.fileName; pb.MouseButton1Click:Connect(function() if isSearchOpen then toggleSearchPanel() end; playMusicFromUrl(ru,rf) end)
                th=th+55
            end
            SearchScrollFrame.CanvasSize=UDim2.new(0,0,0,th)
        else SearchNoResultsLabel.Visible=true; SearchNoResultsLabel.Text="❌ No results found"; SearchScrollFrame.CanvasSize=UDim2.new(0,0,0,0) end
    end
end

function toggleSettingsPanel()
    if isSettingsOpen then TweenService:Create(SettingsPanel,TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Position=UDim2.new(0,0,0,-270)}):Play(); wait(0.3); SettingsPanel.Visible=false; isSettingsOpen=false
    else if isSearchOpen then toggleSearchPanel() end; if isHistoryOpen then toggleHistoryPanel() end; if isInfoOpen then toggleInfoPanel() end; SettingsPanel.Visible=true; isSettingsOpen=true; TweenService:Create(SettingsPanel,TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Position=UDim2.new(0,0,0,-270)}):Play() end
end
function toggleInfoPanel()
    if isInfoOpen then TweenService:Create(InfoPanel,TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Position=UDim2.new(0,-290,0,0)}):Play(); wait(0.3); InfoPanel.Visible=false; isInfoOpen=false
    else if isSearchOpen then toggleSearchPanel() end; if isHistoryOpen then toggleHistoryPanel() end; InfoPanel.Visible=true; isInfoOpen=true; TweenService:Create(InfoPanel,TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Position=UDim2.new(0,-290,0,0)}):Play() end
end
function toggleSearchPanel()
    if isHistoryOpen then toggleHistoryPanel() end; isSearchOpen=not isSearchOpen
    if isSearchOpen then SearchPanel.Visible=true; TweenService:Create(SearchPanel,TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Position=UDim2.new(1,10,0,0)}):Play(); SearchTextBox.Text=""; SearchTextBox:CaptureFocus(); for _,c in pairs(SearchScrollFrame:GetChildren()) do if c.Name=="SearchResultItem" then c:Destroy() end end; SearchNoResultsLabel.Visible=true; SearchNoResultsLabel.Text="🔍 Enter song name or paste URL"
    else TweenService:Create(SearchPanel,TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Position=UDim2.new(1,310,0,0)}):Play(); wait(0.3); SearchPanel.Visible=false end
end
function toggleHistoryPanel()
    if isSearchOpen then toggleSearchPanel() end; isHistoryOpen=not isHistoryOpen
    if isHistoryOpen then HistoryPanel.Visible=true; TweenService:Create(HistoryPanel,TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Position=UDim2.new(0,0,0,0)}):Play(); HistoryButton.Text="← HISTORY"; updateHistoryList()
    else TweenService:Create(HistoryPanel,TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Position=UDim2.new(1,0,0,0)}):Play(); HistoryButton.Text="→ HISTORY"; wait(0.3); HistoryPanel.Visible=false end
end
function updateHistoryList()
    for _,c in pairs(HistoryScrollFrame:GetChildren()) do if c.Name=="HistoryItem" then c:Destroy() end end; NoHistoryLabel.Visible=#downloadHistory==0
    if #downloadHistory==0 then HistoryScrollFrame.CanvasSize=UDim2.new(0,0,0,0); return end
    local ih,spc,th=45,5,0
    for i,e in ipairs(downloadHistory) do
        local ce,ci={url=e.url,fileName=e.fileName,date=e.date},i
        local it=Instance.new("Frame"); it.Name="HistoryItem"; it.Size=UDim2.new(1,-10,0,ih); it.Position=UDim2.new(0,5,0,th); it.BackgroundColor3=i%2==0 and Color3.fromRGB(55,55,55) or Color3.fromRGB(50,50,50); it.BorderSizePixel=0; it.Parent=HistoryScrollFrame
        local ic=Instance.new("UICorner"); ic.CornerRadius=UDim.new(0,4); ic.Parent=it
        local fl=Instance.new("TextLabel"); fl.Size=UDim2.new(0.6,-5,0,20); fl.Position=UDim2.new(0,5,0,5); fl.BackgroundTransparency=1; fl.Text=ce.fileName or "Unknown"; fl.TextColor3=Color3.fromRGB(255,255,255); fl.Font=Enum.Font.Gotham; fl.TextSize=11; fl.TextTruncate=Enum.TextTruncate.AtEnd; fl.Parent=it
        local dl=Instance.new("TextLabel"); dl.Size=UDim2.new(0.6,-5,0,15); dl.Position=UDim2.new(0,5,0,25); dl.BackgroundTransparency=1; dl.Text=ce.date or "Unknown"; dl.TextColor3=Color3.fromRGB(180,180,180); dl.Font=Enum.Font.Gotham; dl.TextSize=9; dl.Parent=it
        local pb=Instance.new("TextButton"); pb.Size=UDim2.new(0.15,-5,0,25); pb.Position=UDim2.new(0.6,5,0,10); pb.BackgroundColor3=Color3.fromRGB(70,150,70); pb.BorderSizePixel=0; pb.Text="▶"; pb.TextColor3=Color3.fromRGB(255,255,255); pb.Font=Enum.Font.GothamBold; pb.TextSize=12; pb.Parent=it
        local pbc=Instance.new("UICorner"); pbc.CornerRadius=UDim.new(0,4); pbc.Parent=pb
        local db=Instance.new("TextButton"); db.Size=UDim2.new(0.15,-5,0,25); db.Position=UDim2.new(0.8,10,0,10); db.BackgroundColor3=Color3.fromRGB(200,80,80); db.BorderSizePixel=0; db.Text="🗑️"; db.TextColor3=Color3.fromRGB(255,255,255); db.Font=Enum.Font.Gotham; db.TextSize=12; db.Parent=it
        local dbc=Instance.new("UICorner"); dbc.CornerRadius=UDim.new(0,4); dbc.Parent=db
        pb.MouseButton1Click:Connect(function() if ce and ce.url then if isHistoryOpen then toggleHistoryPanel() end; playMusicFromUrl(ce.url,ce.fileName or "audio.mp3") end end)
        db.MouseButton1Click:Connect(function() if removeFromHistory(ci) then updateHistoryList() end end)
        th=th+ih+spc
    end
    HistoryScrollFrame.CanvasSize=UDim2.new(0,0,0,th)
end

-- ========== EVENT CONNECTIONS ==========
SpeedTextBox.FocusLost:Connect(function(ep) applySpeedFromTextBox() end)
SpeedUpButton.MouseButton1Click:Connect(function() updateSpeed(math.min(currentSpeed+0.25,100)) end)
SpeedDownButton.MouseButton1Click:Connect(function() updateSpeed(math.max(currentSpeed-0.25,0)) end)

local dragInput,dragStart,startPos
MainFrame.InputBegan:Connect(function(input) if input.UserInputType==Enum.UserInputType.MouseButton1 and not isDraggingTimeSlider and not isDraggingMiniTimeSlider then dragStart=input.Position; startPos=MainFrame.Position; input.Changed:Connect(function() if input.UserInputState==Enum.UserInputState.End then dragStart=nil end end) end end)
MainFrame.InputChanged:Connect(function(input) if input.UserInputType==Enum.UserInputType.MouseMovement then dragInput=input end end)

VolumeSlider.MouseButton1Down:Connect(function() local cn; cn=RunService.Heartbeat:Connect(function() local mx=mouse.X-VolumeSlider.AbsolutePosition.X; updateVolumeSlider(math.clamp(mx/VolumeSlider.AbsoluteSize.X,0,1)) end); VolumeSlider.MouseButton1Up:Connect(function() cn:Disconnect() end); VolumeSlider.MouseLeave:Connect(function() cn:Disconnect() end) end)
VolumeSlider.MouseButton1Click:Connect(function() local mx=mouse.X-VolumeSlider.AbsolutePosition.X; updateVolumeSlider(math.clamp(mx/VolumeSlider.AbsoluteSize.X,0,1)) end)

CloseButton.MouseButton1Click:Connect(function() if isGameMuted then muteAllGameSounds(false) end; stopMusic(); ScreenGui:Destroy(); MiniScreenGui:Destroy() end)
MinimizeButton.MouseButton1Click:Connect(function() if isMinimized then MainFrame.Size=originalSize; ContentFrame.Visible=true; OutlineFrame.Visible=true; isMinimized=false else if isSearchOpen then isSearchOpen=false; SearchPanel.Visible=false end; if isInfoOpen then isInfoOpen=false; InfoPanel.Visible=false end; if isSettingsOpen then isSettingsOpen=false; SettingsPanel.Visible=false end; MainFrame.Size=minimizedSize; ContentFrame.Visible=false; OutlineFrame.Visible=false; isMinimized=true end end)

SettingsButton.MouseButton1Click:Connect(function() toggleSettingsPanel() end)
ToggleSettingsButton.MouseButton1Click:Connect(function() toggleSettingsPanel() end)
InfoButton.MouseButton1Click:Connect(function() toggleInfoPanel() end)
SearchButton.MouseButton1Click:Connect(function() toggleSearchPanel() end)
SearchPanelButton.MouseButton1Click:Connect(function() searchMusic(SearchTextBox.Text) end)
SearchTextBox.FocusLost:Connect(function(ep) if ep then searchMusic(SearchTextBox.Text) end end)
HistoryButton.MouseButton1Click:Connect(function() toggleHistoryPanel() end)
BackButton.MouseButton1Click:Connect(function() toggleHistoryPanel() end)
MuteToggle.MouseButton1Click:Connect(function() muteAllGameSounds(not isGameMuted) end)

LoopToggle.MouseButton1Click:Connect(function() isLooping=not isLooping; local t=themes[currentTheme] or themes["Default"]; if isLooping then LoopToggle.BackgroundColor3=t.loopColor; LoopToggle.Text="🔁 LOOP: ON"; if currentSound then currentSound.Looped=true end else LoopToggle.BackgroundColor3=Color3.fromRGB(130,130,130); LoopToggle.Text="➡ LOOP: OFF"; if currentSound then currentSound.Looped=false end end end)

PlayButton.MouseButton1Click:Connect(function()
    local url=UrlTextBox.Text
    if url=="" then StatusLabel.Text="❌ Error: Please enter URL"; return end
    if string.sub(string.lower(url),-4)~=".mp3" then StatusLabel.Text="❌ Error: URL must end with .mp3"; return end
    local fn="audio.mp3"; local pts=string.split(url,"/")
    if #pts>0 and string.find(pts[#pts],".mp3") then fn=string.gsub(string.gsub(pts[#pts],"%%20"," "),"%%25","%%") end
    playMusicFromUrl(url,fn)
end)

PauseButton.MouseButton1Click:Connect(function() if not currentSound then StatusLabel.Text="❌ No music playing"; return end; togglePause() end)
StopButton.MouseButton1Click:Connect(function() stopMusic(); if PauseButton then PauseButton.Text="⏸ PAUSE" end; StatusLabel.Text="⏹ Music Stopped"; updateTimeDisplay() end)

-- ========== CONTINUOUS TIME UPDATE LOOP ==========
-- This always runs, updating from the actual sound position
spawn(function()
    while true do
        if currentSound then
            -- Always update the display from the actual sound position
            updateTimeDisplay()
        end
        wait(0.05)
    end
end)

spawn(animateTimeLabelColor)

-- ========== INITIALIZATION ==========
loadSettings()
applyTheme(currentTheme)
updateSaveThemeToggle()
updateMiniPlayToggle()
updateVolumeSlider(currentVolume)
updateSpeed(currentSpeed)
updateTimeDisplay()
musicCache=loadCache()
downloadHistory=loadHistory()
updateHistoryList()
cleanOldCache()

player.CharacterAdded:Connect(function(char) if currentSound and isPlaying then currentSound.Parent=workspace; if not currentSound.IsPlaying then currentSound:Play() end end end)

Players.PlayerRemoving:Connect(function(lp) if lp==player then if isGameMuted then muteAllGameSounds(false) end; stopMusic(); ScreenGui:Destroy(); MiniScreenGui:Destroy() end end)
