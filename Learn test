-- ========== SETTINGS (FIXED: Remember key works independently) ==========
local function loadSettings()
    -- Load theme save setting
    local s, r = pcall(function() if readfile and isfile and isfile(SETTINGS_FILE) then return HttpService:JSONDecode(readfile(SETTINGS_FILE)) end end)
    if s and r then
        if r.theme then currentTheme = r.theme end
        if r.saveThemeEnabled ~= nil then saveThemeEnabled = r.saveThemeEnabled end
        if r.rememberKeyEnabled ~= nil then rememberKeyEnabled = r.rememberKeyEnabled end
    end
    -- Load remember key setting separately (always check, independent of saveThemeEnabled)
    local rk, rv = pcall(function() if readfile and isfile and isfile(KEY_FILE) then return HttpService:JSONDecode(readfile(KEY_FILE)) end end)
    if rk and rv then
        if rv.rememberKeyEnabled ~= nil then rememberKeyEnabled = rv.rememberKeyEnabled end
        if rv.isKeyCorrect then
            isKeyCorrect = true
            pcall(function() loadPlaylist() end)
        end
    end
end

local function saveSettings()
    pcall(function()
        if writefile then
            writefile(SETTINGS_FILE, HttpService:JSONEncode({
                theme = currentTheme,
                saveThemeEnabled = saveThemeEnabled,
                rememberKeyEnabled = rememberKeyEnabled
            }))
        end
    end)
end

local function saveKeyState()
    pcall(function()
        if writefile then
            writefile(KEY_FILE, HttpService:JSONEncode({
                rememberKeyEnabled = rememberKeyEnabled,
                isKeyCorrect = isKeyCorrect
