    end
    local tp=currentSound.TimePosition; local tl=currentSound.TimeLength
    if tp~=tp then tp=0 end; if tl~=tl or tl<=0 then tl=1 end
    local timeText=formatTime(tp).." / "..formatTime(tl)
    if TimeLabel then TimeLabel.Text=currentSongName~=""and(timeText.."   "..currentSongName)or timeText end
