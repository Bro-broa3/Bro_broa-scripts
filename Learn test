local function muteAllGameSounds(mute)
    isGameMuted = mute
    
    for _, conn in ipairs(descConnections) do
        pcall(function() conn:Disconnect() end)
    end
    descConnections = {}
    
    pcall(function() 
        SoundService.RespectFilteringEnabled = false
        if mute then 
            originalSoundServiceMuted = SoundService.Muted
            SoundService.Muted = true 
        else 
            SoundService.Muted = originalSoundServiceMuted 
        end 
    end)
    
    local function processSounds(parent)
        pcall(function()
            if parent then
                for _, o in pairs(parent:GetDescendants()) do
                    if o == currentSound then
                        -- DO NOTHING to our music
                    elseif o:IsA("Sound") then
                        if mute then
                            if originalSoundVolumes[o] == nil then
                                originalSoundVolumes[o] = o.Volume
                            end
                            o.Volume = 0
                        else
                            local ov = originalSoundVolumes[o]
                            if ov ~= nil then
                                o.Volume = ov
                                originalSoundVolumes[o] = nil
                            end
                        end
                    elseif o:IsA("SoundGroup") then
                        if mute then
                            if originalSoundGroupVolumes[o] == nil then
                                originalSoundGroupVolumes[o] = o.Volume
                            end
                            o.Volume = 0
                        else
                            local ov = originalSoundGroupVolumes[o]
                            if ov ~= nil then
                                o.Volume = ov
                                originalSoundGroupVolumes[o] = nil
                            end
                        end
                    end
                end
            end
        end)
    end
    
    local services = {
        workspace, game:GetService("Lighting"), game:GetService("ReplicatedStorage"),
        game:GetService("ReplicatedFirst"), game:GetService("ServerStorage"),
        game:GetService("ServerScriptService"), game:GetService("StarterGui"),
        game:GetService("StarterPack"), game:GetService("StarterPlayer"),
        game:GetService("StarterCharacterScripts"), game:GetService("SoundService"),
        game:GetService("Players"), game:GetService("Chat"), game:GetService("TeleportService")
    }
    
    if player then
        if player.Character then table.insert(services, player.Character) end
        if player.Backpack then table.insert(services, player.Backpack) end
        if player.PlayerGui then table.insert(services, player.PlayerGui) end
        if player.PlayerScripts then table.insert(services, player.PlayerScripts) end
    end
    
    pcall(function() 
        if workspace.CurrentCamera then table.insert(services, workspace.CurrentCamera) end 
    end)
    
    for _, service in ipairs(services) do
        processSounds(service)
    end
    
    if mute then
        local function connectDescendantAdded(parent)
            if parent then
                local conn = parent.DescendantAdded:Connect(function(descendant)
                    if descendant == currentSound then
                        -- DO NOTHING to our music
                    elseif descendant:IsA("Sound") then
                        if originalSoundVolumes[descendant] == nil then
                            originalSoundVolumes[descendant] = descendant.Volume
                        end
                        descendant.Volume = 0
                    elseif descendant:IsA("SoundGroup") then
                        if originalSoundGroupVolumes[descendant] == nil then
                            originalSoundGroupVolumes[descendant] = descendant.Volume
                        end
                        descendant.Volume = 0
                    end
                end)
                table.insert(descConnections, conn)
            end
        end
        
        connectDescendantAdded(workspace)
        connectDescendantAdded(game:GetService("Players"))
        if player and player.Character then
            connectDescendantAdded(player.Character)
        end
    end
    
    if currentSound then
        pcall(function() 
            currentSound.Volume = currentVolume
        end)
    end
    
    if not mute then 
        originalSoundVolumes = {}
        originalSoundGroupVolumes = {}
    end
    
    if MuteToggle then
        local t = themes[currentTheme] or themes["Default"]
        MuteToggle.BackgroundColor3 = mute and t.muteOnColor or t.muteColor
        MuteToggle.Text = mute and "🔇 MUTE: ON" or "🔊 MUTE: OFF"
    end
end

