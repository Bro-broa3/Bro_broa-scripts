local function playMusicFromUrl(url,fn)
    stopMusic(); currentSongName=cleanSongName(fn)
    if StatusLabel then StatusLabel.Text="⏬ Loading..."; StatusLabel.TextColor3=Color3.fromRGB(255,200,100) end
    if MiniSongLabel then MiniSongLabel.Text=currentSongName end
    if musicCache[url] and musicCache[url].fileName then
        local cf=musicCache[url].fileName
        if isfile and isfile(cf) then
            if StatusLabel then StatusLabel.Text="📦 Cached"; StatusLabel.TextColor3=Color3.fromRGB(100,200,255) end
            currentSound=Instance.new("Sound"); currentSound.Name="MusicPlayerSound"; currentSound.SoundId=getcustomasset(cf)
            currentSound.Volume=currentVolume; currentSound.Looped=isLooping; currentSound.PlaybackSpeed=currentSpeed; currentSound.Parent=workspace
            currentSound:Play(); isPlaying=true; isPaused=false; pausedTimePosition=0
            if PauseButton then PauseButton.Text="⏸ PAUSE" end
            if StatusLabel then StatusLabel.Text="🎵 "..currentSongName; StatusLabel.TextColor3=Color3.fromRGB(100,255,100) end
            addToHistory(url,fn); updateTimeDisplay(); return true
        else musicCache[url]=nil; saveCache() end
    end
    if StatusLabel then StatusLabel.Text="⏬ Downloading..."; StatusLabel.TextColor3=Color3.fromRGB(255,200,100) end
    local ts=os.time(); local cfn=CACHE_FOLDER.."/cache_"..ts..".mp3"
    local s,err=pcall(function()
        local d=game:HttpGet(url); writefile(cfn,d); musicCache[url]={fileName=cfn,timestamp=ts}; saveCache()
        currentSound=Instance.new("Sound"); currentSound.Name="MusicPlayerSound"; currentSound.SoundId=getcustomasset(cfn)
        currentSound.Volume=currentVolume; currentSound.Looped=isLooping; currentSound.PlaybackSpeed=currentSpeed; currentSound.Parent=workspace
        currentSound:Play(); isPlaying=true; isPaused=false; pausedTimePosition=0
        if PauseButton then PauseButton.Text="⏸ PAUSE" end
    end)
    if s and currentSound then
        if StatusLabel then StatusLabel.Text="🎵 "..currentSongName; StatusLabel.TextColor3=Color3.fromRGB(100,255,100) end
        addToHistory(url,fn); cleanOldCache(); updateTimeDisplay(); return true
    else
        if StatusLabel then StatusLabel.Text="❌ Error: "..tostring(err); StatusLabel.TextColor3=Color3.fromRGB(255,100,100) end
        currentSongName=""; stopMusic(); return false
    end
end

-- ========== PLAYLIST ==========
function loadPlaylist()
    playlistSongs={}
    local s,data=pcall(function() return game:HttpGet("https://raw.githubusercontent.com/Bro-broa3/PrimeMusic/refs/heads/main/Playlist") end)
    if s and data then
        for line in string.gmatch(data,"[^\r\n]+") do
            line=string.gsub(line,"^%s+",""); line=string.gsub(line,"%s+$","")
            if line~=""and string.find(line,".mp3")then
                local url=line; local fileName="audio.mp3"
                local parts=string.split(line,"/")
                if #parts>0 and string.find(parts[#parts],".mp3")then fileName=string.gsub(string.gsub(parts[#parts],"%%20"," "),"%%25","%%") end
                table.insert(playlistSongs,{url=url,fileName=fileName})
            end
        end
    end
end

function checkSecretKey(input)
    if input==secretKey then
        isKeyCorrect=true; SecretKeyTextBox.Text=""
        if rememberKeyEnabled then saveKeyState() end
        loadPlaylist()
        showNotification("GitHub MP3 Player","✅ Key correct! Playlist unlocked!",3)
        if isSearchOpen and currentSearchTab=="Playlist"then updatePlaylistDisplay() end
        return true
    else
        SecretKeyTextBox.Text=""
        showNotification("GitHub MP3 Player","❌ Wrong key! Try again.",3)
        return false
    end
end

