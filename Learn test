-- ========== FORMAT TIME ==========
local function formatTime(s) if s<0 then s=0 end; return string.format("%d:%02d",math.floor(s/60),math.floor(s%60)) end

local rainbowColors = {Color3.fromRGB(255,50,50),Color3.fromRGB(255,150,50),Color3.fromRGB(255,255,50),Color3.fromRGB(50,255,50),Color3.fromRGB(50,150,255),Color3.fromRGB(150,50,255),Color3.fromRGB(255,50,255)}

local function updateTimeDisplay()
    if not currentSound then
        if TimeLabel then TimeLabel.Text="0:00 / 0:00"; TimeLabel.TextColor3=Color3.fromRGB(200,200,200) end
        if TimeSlider then TimeSlider.Size=UDim2.new(0,0,1,0) end
        if MiniTimeLabel then MiniTimeLabel.Text="0:00 / 0:00" end
        if MiniTimeSlider then MiniTimeSlider.Size=UDim2.new(0,0,1,0) end
        return
    end
    local tp=currentSound.TimePosition; local tl=currentSound.TimeLength
    if tp~=tp then tp=0 end; if tl~=tl or tl<=0 then tl=1 end
    local timeText=formatTime(tp).." / "..formatTime(tl)
    if TimeLabel then TimeLabel.Text=currentSongName~=""and(timeText.."   "..currentSongName)or timeText end
    local frac=math.clamp(tp/tl,0,1)
    if TimeSlider then TimeSlider.Size=UDim2.new(frac,0,1,0) end
    if MiniTimeLabel then MiniTimeLabel.Text=timeText end
    if MiniTimeSlider then MiniTimeSlider.Size=UDim2.new(frac,0,1,0) end
    if MiniSongLabel and currentSongName~=""then MiniSongLabel.Text=currentSongName end
    if MiniPauseButton then MiniPauseButton.Text=isPaused and"▶"or"⏸"end
end

local function animateTimeLabelColor()
    local ci=1
    while TimeLabel and TimeLabel.Parent do
        if currentSongName~=""then local c=rainbowColors[ci]; TweenService:Create(TimeLabel,TweenInfo.new(0.5),{TextColor3=c}):Play()
            if MiniSongLabel then TweenService:Create(MiniSongLabel,TweenInfo.new(0.5),{TextColor3=c}):Play() end
            ci=ci+1; if ci>#rainbowColors then ci=1 end
        end; wait(0.5)
    end
end

local function animateTextboxPlaceholder(textbox,texts)
    local ti=1
    while textbox and textbox.Parent do
        local ft=texts[ti]; local ct=""
        for i=1,#ft do if not textbox or not textbox.Parent then return end; ct=ct..string.sub(ft,i,i); textbox.PlaceholderText=ct.."_"; wait(0.15) end
        if not textbox or not textbox.Parent then return end; textbox.PlaceholderText=ft.."_"; wait(0.3)
        for b=1,3 do if not textbox or not textbox.Parent then return end; textbox.PlaceholderText=ft; wait(0.2); if not textbox or not textbox.Parent then return end; textbox.PlaceholderText=ft.."_"; wait(0.2) end
        wait(1.5); if not textbox or not textbox.Parent then return end; textbox.PlaceholderText=""; wait(0.5)
        ti=ti+1; if ti>#texts then ti=1 end
    end
end

