-- ========== UPDATE FUNCTIONS ==========
function updateTimeDisplay()
    if not S.currentSound then
        if UI.TimeLabel then UI.TimeLabel.Text = "0:00 / 0:00" end
        if UI.TimeSlider then UI.TimeSlider.Size = UDim2.new(0, 0, 1, 0) end
        return
    end
    local tp = S.currentSound.TimePosition
    local tl = S.currentSound.TimeLength
    if tp ~= tp then tp = 0 end
    if tl ~= tl or tl <= 0 then tl = 1 end
    if UI.TimeLabel then
        UI.TimeLabel.Text = S.formatTime(tp) .. " / " .. S.formatTime(tl) .. (S.currentSongName ~= "" and "   " .. S.currentSongName or "")
    end
    if UI.TimeSlider and not S.isDraggingTimeSlider then
        UI.TimeSlider.Size = UDim2.new(math.clamp(tp / tl, 0, 1), 0, 1, 0)
    end
    if S.miniPlayerFrame and S.miniPlayerFrame.Visible then
        local mt = S.miniPlayerFrame:FindFirstChild("MiniTime")
        local ms = S.miniPlayerFrame:FindFirstChild("MiniSlider")
        if mt then mt.Text = S.formatTime(tp) .. " / " .. S.formatTime(tl) end
        if ms and not S.isDraggingTimeSlider then
            ms.Size = UDim2.new(math.clamp(tp / tl, 0, 1), 0, 1, 0)
        end
    end
end

