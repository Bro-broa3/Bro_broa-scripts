-- Keyboard shortcuts
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.P and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        if S.currentSound then S.togglePause(); UI.PauseButton.Text = S.isPaused and "▶ RESUME" or "⏸ PAUSE"; updateMiniDisplay()
        else
            local url = UI.UrlTextBox.Text
            if url ~= "" and string.sub(string.lower(url), -4) == ".mp3" then
                local fn = "audio.mp3"; local parts = string.split(url, "/")
                if #parts > 0 and string.find(parts[#parts], ".mp3") then fn = string.gsub(string.gsub(parts[#parts], "%%20", " "), "%%25", "%%") end
                S.playMusicFromUrl(url, fn); S.addToQueue(url, fn); S.currentQueueIndex = #S.playQueue
                UI.PauseButton.Text = "⏸ PAUSE"; if UI.StatusLabel then UI.StatusLabel.Text = "🎵 " .. S.currentSongName end
                updateMiniDisplay(); updateQueueDisplay()
            end
        end
    elseif input.KeyCode == Enum.KeyCode.S and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        S.stopMusic(); UI.PauseButton.Text = "⏸ PAUSE"; if UI.StatusLabel then UI.StatusLabel.Text = "⏹ Music Stopped" end
        updateTimeDisplay(); updateMiniDisplay()
    elseif input.KeyCode == Enum.KeyCode.M and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        S.muteAllGameSounds(not S.isMuted)
        local theme = S.themes[S.currentTheme] or S.themes["Default"]
        if S.isMuted then UI.MuteToggle.BackgroundColor3 = theme.muteOnColor; UI.MuteToggle.Text = "🔇 MUTE: ON"
        else UI.MuteToggle.BackgroundColor3 = theme.muteColor; UI.MuteToggle.Text = "🔊 MUTE: OFF" end
    elseif input.KeyCode == Enum.KeyCode.Right and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        S.playNextInQueue(); updateMiniDisplay(); updateQueueDisplay()
    elseif input.KeyCode == Enum.KeyCode.Left and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        S.playPreviousInQueue(); updateMiniDisplay(); updateQueueDisplay()
    elseif input.KeyCode == Enum.KeyCode.L and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        S.cycleLoopMode(); UI.LoopToggle.BackgroundColor3 = S.getLoopModeColor(); UI.LoopToggle.Text = S.getLoopModeText()
    end
end)

