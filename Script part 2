function searchMusic(searchTerm)
    if not UI.SearchScrollFrame then return end
    for _, child in pairs(UI.SearchScrollFrame:GetChildren()) do
        if child.Name == "MusicItem" then child:Destroy() end
    end
    if searchTerm == "" then
        UI.SearchNoResultsLabel.Visible = true; UI.SearchNoResultsLabel.Text = "🔍 Enter a search term or URL"
        UI.SearchScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0); return
    end
    UI.SearchNoResultsLabel.Visible = false
    local isFullUrl = string.find(searchTerm, "http") and string.find(searchTerm, ".mp3")
    if isFullUrl then
        local success, result = pcall(function() return game:HttpGet(searchTerm) end)
        if success and result and #result > 0 then
            local fn = "audio.mp3"
            local parts = string.split(searchTerm, "/")
            if #parts > 0 and string.find(parts[#parts], ".mp3") then fn = string.gsub(string.gsub(parts[#parts], "%%20", " "), "%%25", "%%") end
            local item = Instance.new("Frame", UI.SearchScrollFrame)
            item.Name = "MusicItem"; item.Size = UDim2.new(1, -10, 0, 60); item.Position = UDim2.new(0, 5, 0, 0)
            item.BackgroundColor3 = Color3.fromRGB(50, 50, 60); item.BorderSizePixel = 0
            Instance.new("UICorner", item).CornerRadius = UDim.new(0, 4)
            local nm = Instance.new("TextLabel", item); nm.Size = UDim2.new(1, -75, 0, 20); nm.Position = UDim2.new(0, 8, 0, 5)
            nm.BackgroundTransparency = 1; nm.Text = S.cleanSongName(fn); nm.TextColor3 = Color3.fromRGB(255, 255, 255)
            nm.Font = Enum.Font.GothamBold; nm.TextSize = 12; nm.TextTruncate = Enum.TextTruncate.AtEnd
            local pb = Instance.new("TextButton", item); pb.Size = UDim2.new(0, 60, 0, 25); pb.Position = UDim2.new(1, -65, 0, 5)
            pb.BackgroundColor3 = Color3.fromRGB(70, 150, 70); pb.BorderSizePixel = 0; pb.Text = "▶ PLAY"
            pb.TextColor3 = Color3.fromRGB(255, 255, 255); pb.Font = Enum.Font.GothamBold; pb.TextSize = 10
            Instance.new("UICorner", pb).CornerRadius = UDim.new(0, 4)
            pb.MouseButton1Click:Connect(function()
                toggleSearchPanel(); S.playMusicFromUrl(searchTerm, fn)
                S.addToQueue(searchTerm, fn); S.currentQueueIndex = #S.playQueue
            end)
            local qb = Instance.new("TextButton", item); qb.Size = UDim2.new(0, 60, 0, 22); qb.Position = UDim2.new(1, -65, 0, 32)
            qb.BackgroundColor3 = Color3.fromRGB(150, 100, 200); qb.BorderSizePixel = 0; qb.Text = "+ QUEUE"
            qb.TextColor3 = Color3.fromRGB(255, 255, 255); qb.Font = Enum.Font.GothamBold; qb.TextSize = 9
            Instance.new("UICorner", qb).CornerRadius = UDim.new(0, 4)
            qb.MouseButton1Click:Connect(function() S.addToQueue(searchTerm, fn); if UI.StatusLabel then UI.StatusLabel.Text = "➕ Added: " .. S.cleanSongName(fn) end end)
            UI.SearchScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 65)
        else
            UI.SearchNoResultsLabel.Visible = true; UI.SearchNoResultsLabel.Text = "❌ URL not found or inaccessible"
            UI.SearchScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
        end
    else
        local found = {}
        pcall(function()
            local base = "https://github.com/Bro-broa3/PrimeMusic/raw/main/"
            local names = {string.gsub(searchTerm, " ", "%%20") .. ".mp3", string.gsub(string.lower(searchTerm), " ", "%%20") .. ".mp3", string.gsub(searchTerm, " ", "") .. ".mp3"}
            for _, fn in ipairs(names) do
                pcall(function()
                    local r = game:HttpGet(base .. fn)
                    if r and #r > 1000 then table.insert(found, {url = base .. fn, fileName = string.gsub(fn, "%%20", " ")}) end
                end)
            end
        end)
        if #found > 0 then
            local th = 0
            for _, r in ipairs(found) do
                local item = Instance.new("Frame", UI.SearchScrollFrame)
                item.Name = "MusicItem"; item.Size = UDim2.new(1, -10, 0, 60); item.Position = UDim2.new(0, 5, 0, th)
                item.BackgroundColor3 = Color3.fromRGB(50, 50, 60); item.BorderSizePixel = 0
                Instance.new("UICorner", item).CornerRadius = UDim.new(0, 4)
                local nm = Instance.new("TextLabel", item); nm.Size = UDim2.new(1, -75, 0, 20); nm.Position = UDim2.new(0, 8, 0, 5)
                nm.BackgroundTransparency = 1; nm.Text = S.cleanSongName(r.fileName); nm.TextColor3 = Color3.fromRGB(255, 255, 255)
                nm.Font = Enum.Font.GothamBold; nm.TextSize = 12; nm.TextTruncate = Enum.TextTruncate.AtEnd
                local pb = Instance.new("TextButton", item); pb.Size = UDim2.new(0, 60, 0, 25); pb.Position = UDim2.new(1, -65, 0, 5)
                pb.BackgroundColor3 = Color3.fromRGB(70, 150, 70); pb.BorderSizePixel = 0; pb.Text = "▶ PLAY"
                pb.TextColor3 = Color3.fromRGB(255, 255, 255); pb.Font = Enum.Font.GothamBold; pb.TextSize = 10
                Instance.new("UICorner", pb).CornerRadius = UDim.new(0, 4)
                pb.MouseButton1Click:Connect(function()
                    toggleSearchPanel(); S.playMusicFromUrl(r.url, r.fileName)
                    S.addToQueue(r.url, r.fileName); S.currentQueueIndex = #S.playQueue
                end)
                local qb = Instance.new("TextButton", item); qb.Size = UDim2.new(0, 60, 0, 22); qb.Position = UDim2.new(1, -65, 0, 32)
                qb.BackgroundColor3 = Color3.fromRGB(150, 100, 200); qb.BorderSizePixel = 0; qb.Text = "+ QUEUE"
                qb.TextColor3 = Color3.fromRGB(255, 255, 255); qb.Font = Enum.Font.GothamBold; qb.TextSize = 9
                Instance.new("UICorner", qb).CornerRadius = UDim.new(0, 4)
                qb.MouseButton1Click:Connect(function() S.addToQueue(r.url, r.fileName); if UI.StatusLabel then UI.StatusLabel.Text = "➕ Added: " .. S.cleanSongName(r.fileName) end end)
                th = th + 65
            end
            UI.SearchScrollFrame.CanvasSize = UDim2.new(0, 0, 0, th)
        else
            UI.SearchNoResultsLabel.Visible = true; UI.SearchNoResultsLabel.Text = "❌ No results found"
            UI.SearchScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
        end
    end
end

