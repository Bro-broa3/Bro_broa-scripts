function shared.MP3Player.addToHistory(url, fileName)
    for i, entry in ipairs(shared.MP3Player.downloadHistory) do
        if entry.url == url then table.remove(shared.MP3Player.downloadHistory, i); break end
    end
    table.insert(shared.MP3Player.downloadHistory, 1, {url = url, fileName = fileName, timestamp = os.time(), date = os.date("%Y-%m-%d %H:%M:%S")})
    if #shared.MP3Player.downloadHistory > 50 then
        for i = 51, #shared.MP3Player.downloadHistory do shared.MP3Player.downloadHistory[i] = nil end
    end
    shared.MP3Player.saveHistory()
end

function shared.MP3Player.removeFromHistory(index)
    if shared.MP3Player.downloadHistory[index] then
        table.remove(shared.MP3Player.downloadHistory, index)
        shared.MP3Player.saveHistory()
        return true
    end
    return false
end

-- Settings
function shared.MP3Player.loadSettings()
    local success, result = pcall(function()
        if readfile and isfile and isfile(shared.MP3Player.SETTINGS_FILE) then
            return HttpService:JSONDecode(readfile(shared.MP3Player.SETTINGS_FILE))
        end
    end)
    if success and result then
        if result.theme then shared.MP3Player.currentTheme = result.theme end
