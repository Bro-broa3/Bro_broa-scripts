end

function shared.MP3Player.saveSettings()
    if not shared.MP3Player.saveThemeEnabled then return end
    pcall(function()
        if writefile then
            local settings = {theme = shared.MP3Player.currentTheme, saveThemeEnabled = shared.MP3Player.saveThemeEnabled, loopMode = shared.MP3Player.loopMode}
            if shared.MP3Player.customAccentColor then
                settings.customAccentColor = {r = shared.MP3Player.customAccentColor.R, g = shared.MP3Player.customAccentColor.G, b = shared.MP3Player.customAccentColor.B}
            end
            writefile(shared.MP3Player.SETTINGS_FILE, HttpService:JSONEncode(settings))
        end
    end)
end

