-- Cleanup
function shared.MP3Player.cleanup()
    for _, conn in pairs(shared.MP3Player.heartbeatConnections) do
        pcall(function() conn:Disconnect() end)
    end
    shared.MP3Player.heartbeatConnections = {}
    shared.MP3Player.sleepTimerRunning = false
end

-- Clean song name
function shared.MP3Player.cleanSongName(fileName)
    if not fileName then return "Unknown" end
    local name = fileName
    name = string.gsub(name, "%.mp3$", ""); name = string.gsub(name, "%.MP3$", "")
    name = string.gsub(name, "%.wav$", ""); name = string.gsub(name, "%.ogg$", "")
    name = string.gsub(name, "%.flac$", ""); name = string.gsub(name, "%.m4a$", "")
    name = string.gsub(name, "%%20", " "); name = string.gsub(name, "%%25", "%%")
    name = string.gsub(name, "_", " "); name = string.gsub(name, "%-", " ")
    return name
end

-- Format time
function shared.MP3Player.formatTime(seconds)
    if seconds < 0 then seconds = 0 end
    local mins = math.floor(seconds / 60)
    local secs = math.floor(seconds % 60)
    return string.format("%d:%02d", mins, secs)
end

-- Volume icon
function shared.MP3Player.getVolumeIcon(vol)
    if vol <= 0 then return "🔇"
    elseif vol <= 0.33 then return "🔈"
    elseif vol <= 0.66 then return "🔉"
    else return "🔊" end
end

-- Hover animation
function shared.MP3Player.addHoverAnimation(button)
    local originalSize = button.Size
    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = originalSize + UDim2.new(0, 4, 0, 4)}):Play()
    end)
    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = originalSize}):Play()
    end)
    button.MouseButton1Down:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.05), {Size = originalSize - UDim2.new(0, 2, 0, 2)}):Play()
    end)
    button.MouseButton1Up:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.1, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = originalSize}):Play()
    end)
end

