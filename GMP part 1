-- State
function shared.MP3Player.saveState()
    pcall(function()
        if writefile then
            local state = {
                volume = shared.MP3Player.currentVolume, speed = shared.MP3Player.currentSpeed,
                muted = shared.MP3Player.isMuted, loopMode = shared.MP3Player.loopMode,
                lastUrl = shared.MP3Player.playQueue[shared.MP3Player.currentQueueIndex] and shared.MP3Player.playQueue[shared.MP3Player.currentQueueIndex].url,
                lastFileName = shared.MP3Player.currentSongName,
                queue = shared.MP3Player.playQueue, queueIndex = shared.MP3Player.currentQueueIndex
            }
            writefile(shared.MP3Player.STATE_FILE, HttpService:JSONEncode(state))
        end
    end)
end

function shared.MP3Player.loadState()
    local success, result = pcall(function()
        if readfile and isfile and isfile(shared.MP3Player.STATE_FILE) then
            return HttpService:JSONDecode(readfile(shared.MP3Player.STATE_FILE))
        end
    end)
    if success and result then
        if result.volume then shared.MP3Player.currentVolume = result.volume end
        if result.speed then shared.MP3Player.currentSpeed = result.speed end
        if result.muted ~= nil then shared.MP3Player.isMuted = result.muted end
        if result.loopMode then shared.MP3Player.loopMode = result.loopMode end
        if result.queue then shared.MP3Player.playQueue = result.queue end
        if result.queueIndex then shared.MP3Player.currentQueueIndex = result.queueIndex end
        return result.lastUrl, result.lastFileName
    end
    return nil, nil
end

-- Loop mode
function shared.MP3Player.getLoopModeText()
    if shared.MP3Player.loopMode == "single" then return "🔂 LOOP: ONE"
    elseif shared.MP3Player.loopMode == "all" then return "🔄 LOOP: ALL"
    else return "➡ NO LOOP" end
end

function shared.MP3Player.getLoopModeColor()
    local theme = shared.MP3Player.themes[shared.MP3Player.currentTheme] or shared.MP3Player.themes["Default"]
    if shared.MP3Player.loopMode == "none" then return Color3.fromRGB(130, 130, 130)
    else return theme.loopColor end
end

function shared.MP3Player.cycleLoopMode()
    if shared.MP3Player.loopMode == "single" then shared.MP3Player.loopMode = "all"
    elseif shared.MP3Player.loopMode == "all" then shared.MP3Player.loopMode = "none"
    else shared.MP3Player.loopMode = "single" end
    if shared.MP3Player.currentSound then
        shared.MP3Player.currentSound.Looped = (shared.MP3Player.loopMode == "single")
    end
    shared.MP3Player.saveSettings()
    shared.MP3Player.saveState()
end

-- Sleep timer
function shared.MP3Player.setSleepTimer(minutes)
    if minutes <= 0 then
        shared.MP3Player.sleepTimerRunning = false
        shared.MP3Player.sleepTimer = 0
        shared.MP3Player.sleepTimerEnd = 0
        return
    end
    shared.MP3Player.sleepTimer = minutes
    shared.MP3Player.sleepTimerEnd = os.time() + (minutes * 60)
    shared.MP3Player.sleepTimerRunning = true
end

-- Queue
function shared.MP3Player.addToQueue(url, fileName)
    for _, entry in ipairs(shared.MP3Player.playQueue) do
        if entry.url == url then return false end
    end
    table.insert(shared.MP3Player.playQueue, {url = url, fileName = fileName})
    shared.MP3Player.saveState()
    return true
end

function shared.MP3Player.removeFromQueue(index)
    if shared.MP3Player.playQueue[index] then
        table.remove(shared.MP3Player.playQueue, index)
        if shared.MP3Player.currentQueueIndex > #shared.MP3Player.playQueue then
            shared.MP3Player.currentQueueIndex = #shared.MP3Player.playQueue
        elseif shared.MP3Player.currentQueueIndex >= index then
            shared.MP3Player.currentQueueIndex = math.max(0, shared.MP3Player.currentQueueIndex - 1)
        end
        shared.MP3Player.saveState()
        return true
    end
    return false
end

-- Core music functions
function shared.MP3Player.stopMusic()
    if shared.MP3Player.currentSound then
        shared.MP3Player.currentSound:Stop()
        shared.MP3Player.currentSound:Destroy()
        shared.MP3Player.currentSound = nil
    end
    shared.MP3Player.isPlaying = false
    shared.MP3Player.isPaused = false
    shared.MP3Player.pausedTimePosition = 0
    shared.MP3Player.currentSongName = ""
end

function shared.MP3Player.playNextInQueue()
    if #shared.MP3Player.playQueue == 0 then return false end
    if shared.MP3Player.loopMode == "none" and shared.MP3Player.currentQueueIndex >= #shared.MP3Player.playQueue then
        shared.MP3Player.stopMusic()
        return false
    end
    shared.MP3Player.currentQueueIndex = shared.MP3Player.currentQueueIndex + 1
    if shared.MP3Player.currentQueueIndex > #shared.MP3Player.playQueue then
        shared.MP3Player.currentQueueIndex = 1
    end
    local entry = shared.MP3Player.playQueue[shared.MP3Player.currentQueueIndex]
    if entry then shared.MP3Player.playMusicFromUrl(entry.url, entry.fileName); return true end
    return false
end

function shared.MP3Player.playPreviousInQueue()
    if #shared.MP3Player.playQueue == 0 then return false end
    shared.MP3Player.currentQueueIndex = shared.MP3Player.currentQueueIndex - 1
    if shared.MP3Player.currentQueueIndex < 1 then shared.MP3Player.currentQueueIndex = #shared.MP3Player.playQueue end
    local entry = shared.MP3Player.playQueue[shared.MP3Player.currentQueueIndex]
    if entry then shared.MP3Player.playMusicFromUrl(entry.url, entry.fileName); return true end
    return false
end

function shared.MP3Player.togglePause()
    if not shared.MP3Player.currentSound then return end
    if shared.MP3Player.isPaused then
        shared.MP3Player.currentSound.TimePosition = shared.MP3Player.pausedTimePosition
        shared.MP3Player.currentSound:Resume()
        shared.MP3Player.isPaused = false; shared.MP3Player.isPlaying = true
    else
        shared.MP3Player.pausedTimePosition = shared.MP3Player.currentSound.TimePosition
        shared.MP3Player.currentSound:Pause()
        shared.MP3Player.isPaused = true; shared.MP3Player.isPlaying = false
    end
end

function shared.MP3Player.playMusicFromUrl(url, fileName)
    shared.MP3Player.stopMusic()
    shared.MP3Player.currentSongName = shared.MP3Player.cleanSongName(fileName)

    if shared.MP3Player.musicCache[url] and shared.MP3Player.musicCache[url].fileName then
        local cachedFile = shared.MP3Player.musicCache[url].fileName
        if isfile and isfile(cachedFile) then
            shared.MP3Player.currentSound = Instance.new("Sound")
            shared.MP3Player.currentSound.Name = "MusicPlayerSound"
            shared.MP3Player.currentSound.SoundId = getcustomasset(cachedFile)
            shared.MP3Player.currentSound.Volume = 0
            shared.MP3Player.currentSound.Looped = (shared.MP3Player.loopMode == "single")
            shared.MP3Player.currentSound.PlaybackSpeed = shared.MP3Player.currentSpeed
            shared.MP3Player.currentSound.Parent = workspace
            shared.MP3Player.currentSound:Play()
            TweenService:Create(shared.MP3Player.currentSound, TweenInfo.new(0.3), {Volume = shared.MP3Player.isMuted and 0 or shared.MP3Player.currentVolume}):Play()
            shared.MP3Player.isPlaying = true; shared.MP3Player.isPaused = false; shared.MP3Player.pausedTimePosition = 0
            shared.MP3Player.addToHistory(url, fileName)
            shared.MP3Player.saveState()
            shared.MP3Player.currentSound.Ended:Connect(function()
                if not shared.MP3Player.screenGui or not shared.MP3Player.screenGui.Parent then return end
                shared.MP3Player.playNextInQueue()
            end)
            return true
        else
            shared.MP3Player.musicCache[url] = nil; shared.MP3Player.saveCache()
        end
    end

    local timestamp = os.time()
    local cachedFileName = "cache_" .. timestamp .. ".mp3"
    local success, errorMessage = pcall(function()
        local audioData = game:HttpGet(url)
        writefile(cachedFileName, audioData)
        shared.MP3Player.musicCache[url] = {fileName = cachedFileName, timestamp = timestamp}
        shared.MP3Player.saveCache()
        shared.MP3Player.currentSound = Instance.new("Sound")
        shared.MP3Player.currentSound.Name = "MusicPlayerSound"
        shared.MP3Player.currentSound.SoundId = getcustomasset(cachedFileName)
        shared.MP3Player.currentSound.Volume = 0
        shared.MP3Player.currentSound.Looped = (shared.MP3Player.loopMode == "single")
        shared.MP3Player.currentSound.PlaybackSpeed = shared.MP3Player.currentSpeed
        shared.MP3Player.currentSound.Parent = workspace
        shared.MP3Player.currentSound:Play()
        TweenService:Create(shared.MP3Player.currentSound, TweenInfo.new(0.3), {Volume = shared.MP3Player.isMuted and 0 or shared.MP3Player.currentVolume}):Play()
        shared.MP3Player.isPlaying = true; shared.MP3Player.isPaused = false; shared.MP3Player.pausedTimePosition = 0
    end)
    if success and shared.MP3Player.currentSound then
        shared.MP3Player.addToHistory(url, fileName)
        shared.MP3Player.cleanOldCache()
        shared.MP3Player.saveState()
        shared.MP3Player.currentSound.Ended:Connect(function()
            if not shared.MP3Player.screenGui or not shared.MP3Player.screenGui.Parent then return end
            shared.MP3Player.playNextInQueue()
        end)
        return true
    else
        shared.MP3Player.currentSongName = ""
        shared.MP3Player.stopMusic()
        return false
    end
end

function shared.MP3Player.muteAllGameSounds(mute)
    shared.MP3Player.isMuted = mute
    pcall(function()
        SoundService.RespectFilteringEnabled = false
        if mute then shared.MP3Player.originalSoundServiceMuted = SoundService.Muted; SoundService.Muted = true
        else SoundService.Muted = shared.MP3Player.originalSoundServiceMuted end
    end)
    if not mute then shared.MP3Player.originalSoundVolumes = {}; shared.MP3Player.originalSoundGroupVolumes = {} end
    if shared.MP3Player.currentSound then
        pcall(function() shared.MP3Player.currentSound.Volume = mute and 0 or shared.MP3Player.currentVolume end)
    end
    shared.MP3Player.saveState()
end

function shared.MP3Player.updateVolumeSlider(volume)
    shared.MP3Player.currentVolume = volume
    if shared.MP3Player.currentSound and not shared.MP3Player.isMuted then
        shared.MP3Player.currentSound.Volume = volume
    end
    shared.MP3Player.saveState()
end

function shared.MP3Player.updateSpeed(speed)
    shared.MP3Player.currentSpeed = speed
    if shared.MP3Player.currentSound then shared.MP3Player.currentSound.PlaybackSpeed = speed end
    shared.MP3Player.saveState()
end

