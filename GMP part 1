function shared.MP3Player.cleanOldCache()
    pcall(function()
        if listfiles then
            local files = listfiles()
            local cacheFiles = {}
            for _, file in ipairs(files) do
                if string.find(file, "cache_") and string.find(file, ".mp3") then
                    table.insert(cacheFiles, file)
                end
            end
            table.sort(cacheFiles, function(a, b) return a > b end)
            for i = 21, #cacheFiles do delfile(cacheFiles[i]) end
        end
    end)
end

