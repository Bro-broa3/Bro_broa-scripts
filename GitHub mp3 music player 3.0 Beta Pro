    if downloadHistory[index] then
        table.remove(downloadHistory, index)
        saveHistory()
        return true
    end
    return false
end

local function stopMusic()
    if currentSound then
        currentSound:Stop()
        currentSound:Destroy()
        currentSound = nil
    end
    isPlaying = false
    isPaused = false
    pausedTimePosition = 0
    currentSongName = ""
    updateTimeDisplay()
    saveState()
