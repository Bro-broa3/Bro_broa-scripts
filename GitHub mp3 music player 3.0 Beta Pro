-- ========== CLEAN SONG NAME FUNCTION ==========
local function cleanSongName(fileName)
    if not fileName then return "Unknown" end
    local name = fileName
    name = string.gsub(name, "%.mp3$", "")
    name = string.gsub(name, "%.MP3$", "")
    name = string.gsub(name, "%.wav$", "")
    name = string.gsub(name, "%.ogg$", "")
    name = string.gsub(name, "%.flac$", "")
    name = string.gsub(name, "%.m4a$", "")
    name = string.gsub(name, "%%20", " ")
    name = string.gsub(name, "%%25", "%%")
    name = string.gsub(name, "_", " ")
    name = string.gsub(name, "%-", " ")
    return name
end

