local function addToHistory(url, fileName)
    for i, entry in ipairs(downloadHistory) do
        if entry.url == url then table.remove(downloadHistory, i); break end
    end
    local historyEntry = {url = url, fileName = fileName, timestamp = os.time(), date = os.date("%Y-%m-%d %H:%M:%S")}
    table.insert(downloadHistory, 1, historyEntry)
    if #downloadHistory > 50 then
        for i = 51, #downloadHistory do downloadHistory[i] = nil end
    end
    saveHistory()
end

