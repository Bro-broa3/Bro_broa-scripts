            SearchScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 70)
        else SearchNoResultsLabel.Visible = true; SearchNoResultsLabel.Text = "❌ URL not found or inaccessible"; SearchScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0) end
    else
        local foundResults = {}
        pcall(function()
            local baseUrl = "https://github.com/Bro-broa3/PrimeMusic/raw/main/"
            local possibleFiles = {string.gsub(searchTerm, " ", "%%20") .. ".mp3", string.gsub(string.lower(searchTerm), " ", "%%20") .. ".mp3", string.gsub(searchTerm, " ", "") .. ".mp3", string.gsub(string.lower(searchTerm), " ", "_") .. ".mp3", string.gsub(string.lower(searchTerm), " ", "-") .. ".mp3", string.lower(string.gsub(searchTerm, " ", "")) .. ".mp3"}
            for _, fileName in ipairs(possibleFiles) do
