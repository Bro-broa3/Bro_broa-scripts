-- ========== FORMAT TIME FUNCTION ==========
local function formatTime(seconds)
    if seconds < 0 then seconds = 0 end
    local mins = math.floor(seconds / 60)
    local secs = math.floor(seconds % 60)
    return string.format("%d:%02d", mins, secs)
end

local function updateTimeDisplay()
    if not currentSound then
        if TimeLabel then TimeLabel.Text = "0:00 / 0:00" end
        if TimeSlider then TimeSlider.Size = UDim2.new(0, 0, 1, 0) end
        return
    end
    local timePos = currentSound.TimePosition
    local timeLength = currentSound.TimeLength
    if timePos ~= timePos then timePos = 0 end
    if timeLength ~= timeLength or timeLength <= 0 then timeLength = 1 end
    if TimeLabel then
        local displayText = formatTime(timePos) .. " / " .. formatTime(timeLength)
        if currentSongName ~= "" then
            displayText = displayText .. "   " .. currentSongName
        end
        TimeLabel.Text = displayText
    end
    if TimeSlider and not isDraggingTimeSlider then
        local fraction = math.clamp(timePos / timeLength, 0, 1)
        TimeSlider.Size = UDim2.new(fraction, 0, 1, 0)
    end
end

-- ========== QUEUE FUNCTIONS ==========
local function addToQueue(url, fileName)
    table.insert(playQueue, {url = url, fileName = fileName})
    saveState()
    updateQueueDisplay()
end

local function removeFromQueue(index)
    if playQueue[index] then
        table.remove(playQueue, index)
        if currentQueueIndex > #playQueue then
            currentQueueIndex = #playQueue
        end
        saveState()
        updateQueueDisplay()
        return true
    end
    return false
end

local function playNextInQueue()
    if #playQueue == 0 then return false end
    currentQueueIndex = currentQueueIndex + 1
    if currentQueueIndex > #playQueue then
        currentQueueIndex = 1
        if not isLooping then
            stopMusic()
            StatusLabel.Text = "✅ Queue finished"
            return false
        end
    end
    local entry = playQueue[currentQueueIndex]
    if entry then
        playMusicFromUrl(entry.url, entry.fileName)
        return true
    end
    return false
end

local function playPreviousInQueue()
    if #playQueue == 0 then return false end
    currentQueueIndex = currentQueueIndex - 1
    if currentQueueIndex < 1 then
        currentQueueIndex = #playQueue
    end
    local entry = playQueue[currentQueueIndex]
    if entry then
        playMusicFromUrl(entry.url, entry.fileName)
        return true
    end
    return false
end

