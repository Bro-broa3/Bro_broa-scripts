UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    -- Ctrl+Shift shortcuts
    if input.KeyCode == Enum.KeyCode.P and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        if currentSound then
            togglePause()
        else
            -- Try to play from URL box
            local url = UrlTextBox.Text
            if url ~= "" and string.sub(string.lower(url), -4) == ".mp3" then
                local fileName = "audio.mp3"; local urlParts = string.split(url, "/")
                if #urlParts > 0 then local lastPart = urlParts[#urlParts]; if string.find(lastPart, ".mp3") then fileName = string.gsub(string.gsub(lastPart, "%%20", " "), "%%25", "%%") end end
                playMusicFromUrl(url, fileName)
                addToQueue(url, fileName)
                currentQueueIndex = #playQueue
            end
        end
    elseif input.KeyCode == Enum.KeyCode.S and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        stopMusic()
        if PauseButton then PauseButton.Text = "⏸ PAUSE" end
        StatusLabel.Text = "⏹ Music Stopped"
        updateTimeDisplay()
    elseif input.KeyCode == Enum.KeyCode.M and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        muteAllGameSounds(not isMuted)
    elseif input.KeyCode == Enum.KeyCode.Right and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        playNextInQueue()
    elseif input.KeyCode == Enum.KeyCode.Left and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        playPreviousInQueue()
    end
end)

