        local playBtn = Instance.new("TextButton")
        playBtn.Size = UDim2.new(0, 20, 0, 20)
        playBtn.Position = UDim2.new(1, -30, 0, 10)
        playBtn.BackgroundColor3 = Color3.fromRGB(70, 150, 70)
