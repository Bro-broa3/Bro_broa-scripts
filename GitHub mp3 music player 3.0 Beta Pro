local gradientRunning = true
local function animateGradient()
    local colors = {Color3.fromRGB(255, 50, 50), Color3.fromRGB(255, 150, 50), Color3.fromRGB(255, 255, 50), Color3.fromRGB(50, 255, 50), Color3.fromRGB(50, 150, 255), Color3.fromRGB(150, 50, 255), Color3.fromRGB(255, 50, 255)}
    local currentIndex = 1
    while UIStroke and UIStroke.Parent and gradientRunning do
        local tweenInfo = TweenInfo.new(2, Enum.EasingStyle.Linear)
        local tween = TweenService:Create(UIStroke, tweenInfo, {Color = colors[currentIndex]})
        tween:Play()
        currentIndex = currentIndex + 1
        if currentIndex > #colors then currentIndex = 1 end
        wait(2)
    end
end
