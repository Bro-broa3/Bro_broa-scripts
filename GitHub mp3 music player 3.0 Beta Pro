            local playButton = Instance.new("TextButton"); playButton.Size = UDim2.new(0, 60, 0, 25); playButton.Position = UDim2.new(1, -65, 0, 5); playButton.BackgroundColor3 = Color3.fromRGB(70, 150, 70); playButton.BorderSizePixel = 0; playButton.Text = "PLAY"; playButton.TextColor3 = Color3.fromRGB(255, 255, 255); playButton.Font = Enum.Font.GothamBold; playButton.TextSize = 10; playButton.Parent = resultItem
