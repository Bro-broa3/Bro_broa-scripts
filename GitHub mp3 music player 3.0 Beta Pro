-- ========== SETTINGS SAVE/LOAD ==========
local function loadSettings()
    local success, result = pcall(function()
        if readfile and isfile and isfile(SETTINGS_FILE) then
            return HttpService:JSONDecode(readfile(SETTINGS_FILE))
        end
    end)
    if success and result then
        if result.theme then currentTheme = result.theme end
        if result.saveThemeEnabled ~= nil then saveThemeEnabled = result.saveThemeEnabled end
        if result.customAccentColor then
            customAccentColor = Color3.new(result.customAccentColor.r, result.customAccentColor.g, result.customAccentColor.b)
        end
    end
end

local function saveSettings()
    if not saveThemeEnabled then return end
    pcall(function()
        if writefile then
            local settings = {
                theme = currentTheme,
                saveThemeEnabled = saveThemeEnabled
            }
            if customAccentColor then
                settings.customAccentColor = {r = customAccentColor.R, g = customAccentColor.G, b = customAccentColor.B}
            end
            writefile(SETTINGS_FILE, HttpService:JSONEncode(settings))
        end
    end)
end

