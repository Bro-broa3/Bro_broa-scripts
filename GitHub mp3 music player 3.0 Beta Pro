local function muteAllGameSounds(mute)
    isMuted = mute
    pcall(function()
        SoundService.RespectFilteringEnabled = false
        if mute then originalSoundServiceMuted = SoundService.Muted; SoundService.Muted = true
        else SoundService.Muted = originalSoundServiceMuted end
    end)
    local allServices = {game, workspace, game:GetService("Lighting"), game:GetService("ReplicatedStorage"), game:GetService("ReplicatedFirst"), game:GetService("ServerStorage"), game:GetService("ServerScriptService"), game:GetService("StarterGui"), game:GetService("StarterPack"), game:GetService("StarterPlayer"), game:GetService("StarterCharacterScripts"), game:GetService("SoundService"), game:GetService("Players"), game:GetService("Chat"), game:GetService("TeleportService")}
    if player then
        if player.Character then table.insert(allServices, player.Character) end
        if player.Backpack then table.insert(allServices, player.Backpack) end
        if player.PlayerGui then table.insert(allServices, player.PlayerGui) end
        if player.PlayerScripts then table.insert(allServices, player.PlayerScripts) end
    end
    pcall(function() if workspace.CurrentCamera then table.insert(allServices, workspace.CurrentCamera) end end)
    for _, container in ipairs(allServices) do
        pcall(function()
            if container then
                for _, obj in pairs(container:GetDescendants()) do
                    if obj:IsA("Sound") then
                        if mute then
                            if originalSoundVolumes[obj] == nil then originalSoundVolumes[obj] = obj.Volume end
                            obj.Volume = 0
                        else
                            local origVol = originalSoundVolumes[obj]
                            if origVol ~= nil then obj.Volume = origVol; originalSoundVolumes[obj] = nil end
                        end
                    elseif obj:IsA("SoundGroup") then
                        if mute then
                            if originalSoundGroupVolumes[obj] == nil then originalSoundGroupVolumes[obj] = obj.Volume end
                            obj.Volume = 0
                        else
                            local origVol = originalSoundGroupVolumes[obj]
                            if origVol ~= nil then obj.Volume = origVol; originalSoundGroupVolumes[obj] = nil end
                        end
                    end
                end
            end
        end)
    end
    if currentSound then pcall(function() currentSound.Volume = mute and 0 or currentVolume end) end
    if not mute then originalSoundVolumes = {}; originalSoundGroupVolumes = {} end
    if MuteToggle then
        local theme = themes[currentTheme] or themes["Default"]
        if mute then MuteToggle.BackgroundColor3 = theme.muteOnColor; MuteToggle.Text = "🔇 MUTE: ON"
        else MuteToggle.BackgroundColor3 = theme.muteColor; MuteToggle.Text = "🔊 MUTE: OFF" end
    end
    saveState()
end

local function updateVolumeSlider(volume)
    currentVolume = volume
    if VolumeFill then VolumeFill.Size = UDim2.new(volume, 0, 1, 0) end
    if VolumeLabel then VolumeLabel.Text = "Volume: " .. math.floor(volume * 100) .. "%" end
    if currentSound and not isMuted then currentSound.Volume = volume end
    saveState()
end

local function updateSpeed(speed)
    currentSpeed = speed
    if SpeedTextBox then SpeedTextBox.Text = string.format("%.2f", speed) .. "x" end
    if SpeedLabel then SpeedLabel.Text = "Speed: " .. string.format("%.2f", speed) .. "x" end
    if currentSound then currentSound.PlaybackSpeed = speed end
    saveState()
end

local function togglePause()
    if not currentSound then return end
    if isPaused then
        currentSound.TimePosition = pausedTimePosition; currentSound:Resume()
        isPaused = false; isPlaying = true
        if PauseButton then PauseButton.Text = "⏸ PAUSE" end
    else
        pausedTimePosition = currentSound.TimePosition; currentSound:Pause()
        isPaused = true; isPlaying = false
        if PauseButton then PauseButton.Text = "▶ RESUME" end
    end
    saveState()
end

local function playMusicFromUrl(url, fileName)
    stopMusic()
    currentSongName = cleanSongName(fileName)
    if StatusLabel then StatusLabel.Text = "⏬ Loading..."; StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 100) end

    -- Fade out previous sound if it exists
    -- (already stopped above)

    if musicCache[url] and musicCache[url].fileName then
        local cachedFile = musicCache[url].fileName
        if isfile and isfile(cachedFile) then
            if StatusLabel then StatusLabel.Text = "📦 Using cached file..."; StatusLabel.TextColor3 = Color3.fromRGB(100, 200, 255) end
            currentSound = Instance.new("Sound")
            currentSound.Name = "MusicPlayerSound"
            currentSound.SoundId = getcustomasset(cachedFile)
            currentSound.Volume = isMuted and 0 or currentVolume
            currentSound.Looped = isLooping
            currentSound.PlaybackSpeed = currentSpeed
            currentSound.Parent = workspace

            -- Fade in
            currentSound.Volume = 0
            currentSound:Play()
            local fadeIn = TweenService:Create(currentSound, TweenInfo.new(0.3), {Volume = isMuted and 0 or currentVolume})
            fadeIn:Play()

            isPlaying = true; isPaused = false; pausedTimePosition = 0
            if PauseButton then PauseButton.Text = "⏸ PAUSE" end
            if StatusLabel then StatusLabel.Text = "🎵 Now Playing: " .. currentSongName; StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100) end
            addToHistory(url, fileName)
            saveState()
            updateTimeDisplay()
            -- Auto-play next when this ends
            currentSound.Ended:Connect(function()
                if isLooping and #playQueue <= 1 then
                    -- Looping single song
                else
                    playNextInQueue()
                end
            end)
            return true
        else
            musicCache[url] = nil; saveCache()
        end
    end

    if StatusLabel then StatusLabel.Text = "⏬ Downloading... (one time)"; StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 100) end
    local timestamp = os.time()
    local cachedFileName = "cache_" .. timestamp .. ".mp3"
    local success, errorMessage = pcall(function()
        local audioData = game:HttpGet(url)
        writefile(cachedFileName, audioData)
        musicCache[url] = {fileName = cachedFileName, timestamp = timestamp}
        saveCache()
        currentSound = Instance.new("Sound")
        currentSound.Name = "MusicPlayerSound"
        currentSound.SoundId = getcustomasset(cachedFileName)
        currentSound.Volume = 0  -- Start at 0 for fade in
        currentSound.Looped = isLooping
        currentSound.PlaybackSpeed = currentSpeed
        currentSound.Parent = workspace
        currentSound:Play()

        -- Fade in
        local fadeIn = TweenService:Create(currentSound, TweenInfo.new(0.3), {Volume = isMuted and 0 or currentVolume})
        fadeIn:Play()

        isPlaying = true; isPaused = false; pausedTimePosition = 0
        if PauseButton then PauseButton.Text = "⏸ PAUSE" end
    end)
    if success and currentSound then
        if StatusLabel then StatusLabel.Text = "🎵 Now Playing: " .. currentSongName; StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100) end
        addToHistory(url, fileName)
        cleanOldCache()
        saveState()
        updateTimeDisplay()
        -- Auto-play next when this ends
        currentSound.Ended:Connect(function()
            if isLooping and #playQueue <= 1 then
                -- Looping single song
            else
                playNextInQueue()
            end
        end)
        return true
    else
        if StatusLabel then StatusLabel.Text = "❌ Download failed - check URL"; StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100) end
        currentSongName = ""
        stopMusic()
        return false
    end
end

-- ========== QUEUE DISPLAY UPDATE ==========
function updateQueueDisplay()
    if not QueueScrollFrame then return end
    for _, child in pairs(QueueScrollFrame:GetChildren()) do
        if child.Name == "QueueItem" then child:Destroy() end
    end
    if #playQueue == 0 then
        QueueNoItemsLabel.Visible = true
        QueueScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
