local function applySpeedFromTextBox()
    local text = SpeedTextBox.Text; text = string.gsub(text, "x", ""); text = string.gsub(text, "X", "")
    local speed = tonumber(text)
    if speed then speed = math.clamp(speed, 0, 100); updateSpeed(speed)
    else SpeedTextBox.Text = string.format("%.2f", currentSpeed) .. "x" end
end

local function searchMusic(searchTerm)
    if not SearchScrollFrame then return end
    for _, child in pairs(SearchScrollFrame:GetChildren()) do
        if child.Name == "SearchResultItem" then child:Destroy() end
