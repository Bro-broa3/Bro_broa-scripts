PlayButton.MouseButton1Click:Connect(function()
    local url = UrlTextBox.Text
    if url == "" then StatusLabel.Text = "❌ Please enter a URL"; return end
    if string.sub(string.lower(url), -4) ~= ".mp3" then StatusLabel.Text = "❌ URL must end with .mp3"; return end
    local fileName = "audio.mp3"; local urlParts = string.split(url, "/")
    if #urlParts > 0 then local lastPart = urlParts[#urlParts]; if string.find(lastPart, ".mp3") then fileName = string.gsub(string.gsub(lastPart, "%%20", " "), "%%25", "%%") end end
    playMusicFromUrl(url, fileName)
    -- Auto-add to queue
    addToQueue(url, fileName)
    currentQueueIndex = #playQueue
end)

PauseButton.MouseButton1Click:Connect(function() if not currentSound then StatusLabel.Text = "❌ No music playing"; return end; togglePause() end)
StopButton.MouseButton1Click:Connect(function() stopMusic(); if PauseButton then PauseButton.Text = "⏸ PAUSE" end; StatusLabel.Text = "⏹ Music Stopped"; updateTimeDisplay() end)

