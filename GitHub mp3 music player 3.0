-- ========== FUNCTIONS ==========

local function applySpeedFromTextBox()
    local text = SpeedTextBox.Text
    text = string.gsub(text, "x", "")
    text = string.gsub(text, "X", "")
    local speed = tonumber(text)
    if speed then
        speed = math.clamp(speed, 0, 100)
        updateSpeed(speed)
    else
        SpeedTextBox.Text = string.format("%.2f", currentSpeed) .. "x"
    end
end

local function searchMusic(searchTerm)
    if not SearchScrollFrame then return end
    for _, child in pairs(SearchScrollFrame:GetChildren()) do
        if child.Name == "SearchResultItem" then child:Destroy() end
    end
    if searchTerm == "" then
        if SearchNoResultsLabel then
            SearchNoResultsLabel.Visible = true
            SearchNoResultsLabel.Text = "🔍 Enter a search term or URL"
        end
        SearchScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
        return
    end
    SearchNoResultsLabel.Visible = false
    local isFullUrl = string.find(searchTerm, "http") and string.find(searchTerm, ".mp3")
    if isFullUrl then
        local success, result = pcall(function() return game:HttpGet(searchTerm) end)
        if success and result and #result > 0 then
            local fileName = "audio.mp3"
            local urlParts = string.split(searchTerm, "/")
            if #urlParts > 0 then
                local lastPart = urlParts[#urlParts]
                if string.find(lastPart, ".mp3") then
                    fileName = lastPart
                    fileName = string.gsub(fileName, "%%20", " ")
                    fileName = string.gsub(fileName, "%%25", "%%")
                end
            end
            local resultItem = Instance.new("Frame")
            resultItem.Name = "SearchResultItem"
            resultItem.Size = UDim2.new(1, -10, 0, 50)
            resultItem.Position = UDim2.new(0, 5, 0, 0)
            resultItem.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
            resultItem.BorderSizePixel = 0
            resultItem.Parent = SearchScrollFrame
            local itemCorner = Instance.new("UICorner")
            itemCorner.CornerRadius = UDim.new(0, 4)
            itemCorner.Parent = resultItem
            local urlLabel = Instance.new("TextLabel")
            urlLabel.Size = UDim2.new(1, -70, 0, 20)
            urlLabel.Position = UDim2.new(0, 5, 0, 5)
            urlLabel.BackgroundTransparency = 1
            urlLabel.Text = fileName
            urlLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            urlLabel.TextXAlignment = Enum.TextXAlignment.Left
            urlLabel.Font = Enum.Font.GothamBold
            urlLabel.TextSize = 12
            urlLabel.TextTruncate = Enum.TextTruncate.AtEnd
            urlLabel.Parent = resultItem
            local pathLabel = Instance.new("TextLabel")
            pathLabel.Size = UDim2.new(1, -70, 0, 15)
            pathLabel.Position = UDim2.new(0, 5, 0, 25)
            pathLabel.BackgroundTransparency = 1
            pathLabel.Text = "✓ Direct URL"
            pathLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            pathLabel.TextXAlignment = Enum.TextXAlignment.Left
            pathLabel.Font = Enum.Font.Gotham
            pathLabel.TextSize = 9
            pathLabel.Parent = resultItem
            local playButton = Instance.new("TextButton")
            playButton.Size = UDim2.new(0, 60, 0, 30)
            playButton.Position = UDim2.new(1, -65, 0, 10)
            playButton.BackgroundColor3 = Color3.fromRGB(70, 150, 70)
            playButton.BorderSizePixel = 0
            playButton.Text = "PLAY"
            playButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            playButton.Font = Enum.Font.GothamBold
            playButton.TextSize = 10
            playButton.Parent = resultItem
            local playButtonCorner = Instance.new("UICorner")
            playButtonCorner.CornerRadius = UDim.new(0, 4)
            playButtonCorner.Parent = playButton
            playButton.MouseButton1Click:Connect(function()
                if isSearchOpen then toggleSearchPanel() end
                playMusicFromUrl(searchTerm, fileName)
            end)
            SearchScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 60)
        else
            SearchNoResultsLabel.Visible = true
            SearchNoResultsLabel.Text = "❌ URL not found or inaccessible"
            SearchScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
        end
    else
        local foundResults = {}
        pcall(function()
            local baseUrl = "https://github.com/Bro-broa3/PrimeMusic/raw/main/"
            local possibleFiles = {}
            local encodedName = string.gsub(searchTerm, " ", "%%20")
            local encodedNameLower = string.gsub(string.lower(searchTerm), " ", "%%20")
            table.insert(possibleFiles, encodedName .. ".mp3")
            table.insert(possibleFiles, encodedNameLower .. ".mp3")
            table.insert(possibleFiles, string.gsub(searchTerm, " ", "") .. ".mp3")
            table.insert(possibleFiles, string.gsub(string.lower(searchTerm), " ", "_") .. ".mp3")
            table.insert(possibleFiles, string.gsub(string.lower(searchTerm), " ", "-") .. ".mp3")
            table.insert(possibleFiles, string.lower(string.gsub(searchTerm, " ", "")) .. ".mp3")
            for _, fileName in ipairs(possibleFiles) do
                local fullUrl = baseUrl .. fileName
                local success = pcall(function()
                    local response = game:HttpGet(fullUrl)
                    if response and #response > 1000 then
                        table.insert(foundResults, {url = fullUrl, fileName = string.gsub(fileName, "%%20", " ")})
                    end
                end)
            end
        end)
        if #foundResults > 0 then
            local totalHeight = 0
            for _, result in ipairs(foundResults) do
                local resultItem = Instance.new("Frame")
                resultItem.Name = "SearchResultItem"
                resultItem.Size = UDim2.new(1, -10, 0, 50)
                resultItem.Position = UDim2.new(0, 5, 0, totalHeight)
                resultItem.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
                resultItem.BorderSizePixel = 0
                resultItem.Parent = SearchScrollFrame
                local itemCorner = Instance.new("UICorner")
                itemCorner.CornerRadius = UDim.new(0, 4)
                itemCorner.Parent = resultItem
                local urlLabel = Instance.new("TextLabel")
                urlLabel.Size = UDim2.new(1, -70, 0, 20)
                urlLabel.Position = UDim2.new(0, 5, 0, 5)
                urlLabel.BackgroundTransparency = 1
                urlLabel.Text = result.fileName
                urlLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                urlLabel.Font = Enum.Font.GothamBold
                urlLabel.TextSize = 12
                urlLabel.TextTruncate = Enum.TextTruncate.AtEnd
                urlLabel.Parent = resultItem
                local pathLabel = Instance.new("TextLabel")
                pathLabel.Size = UDim2.new(1, -70, 0, 15)
                pathLabel.Position = UDim2.new(0, 5, 0, 25)
                pathLabel.BackgroundTransparency = 1
                pathLabel.Text = "✓ Found by name"
                pathLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                pathLabel.Font = Enum.Font.Gotham
                pathLabel.TextSize = 9
                pathLabel.Parent = resultItem
                local playButton = Instance.new("TextButton")
                playButton.Size = UDim2.new(0, 60, 0, 30)
                playButton.Position = UDim2.new(1, -65, 0, 10)
                playButton.BackgroundColor3 = Color3.fromRGB(70, 150, 70)
                playButton.BorderSizePixel = 0
                playButton.Text = "PLAY"
                playButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                playButton.Font = Enum.Font.GothamBold
                playButton.TextSize = 10
                playButton.Parent = resultItem
                local playButtonCorner = Instance.new("UICorner")
                playButtonCorner.CornerRadius = UDim.new(0, 4)
                playButtonCorner.Parent = playButton
                local resultUrl = result.url
                local resultFileName = result.fileName
                playButton.MouseButton1Click:Connect(function()
                    if isSearchOpen then toggleSearchPanel() end
                    playMusicFromUrl(resultUrl, resultFileName)
                end)
                totalHeight = totalHeight + 55
            end
            SearchScrollFrame.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
        else
            SearchNoResultsLabel.Visible = true
            SearchNoResultsLabel.Text = "❌ No results found for: " .. searchTerm .. "\nTry a full GitHub raw URL"
            SearchScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
        end
    end
end

function toggleInfoPanel()
    if isInfoOpen then
        local tween = TweenService:Create(InfoPanel, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Position = UDim2.new(0, -290, 0, 0)})
        tween:Play()
        wait(0.3)
        InfoPanel.Visible = false
        isInfoOpen = false
    else
        if isSearchOpen then toggleSearchPanel() end
        if isHistoryOpen then toggleHistoryPanel() end
        InfoPanel.Visible = true
        isInfoOpen = true
        local tween = TweenService:Create(InfoPanel, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0, -290, 0, 0)})
        tween:Play()
    end
end

function toggleSearchPanel()
    if isHistoryOpen then toggleHistoryPanel() end
    isSearchOpen = not isSearchOpen
    if isSearchOpen then
        SearchPanel.Visible = true
        local tween = TweenService:Create(SearchPanel, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(1, 10, 0, 0)})
        tween:Play()
        SearchTextBox.Text = ""
        SearchTextBox:CaptureFocus()
        for _, child in pairs(SearchScrollFrame:GetChildren()) do
            if child.Name == "SearchResultItem" then child:Destroy() end
        end
        SearchNoResultsLabel.Visible = true
        SearchNoResultsLabel.Text = "🔍 Enter song name or paste URL"
    else
        local tween = TweenService:Create(SearchPanel, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Position = UDim2.new(1, 310, 0, 0)})
        tween:Play()
        wait(0.3)
        SearchPanel.Visible = false
    end
end

function toggleHistoryPanel()
    if isSearchOpen then toggleSearchPanel() end
    isHistoryOpen = not isHistoryOpen
    if isHistoryOpen then
        HistoryPanel.Visible = true
        local tween = TweenService:Create(HistoryPanel, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)})
        tween:Play()
        HistoryButton.Text = "← HISTORY"
        updateHistoryList()
    else
        local tween = TweenService:Create(HistoryPanel, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Position = UDim2.new(1, 0, 0, 0)})
        tween:Play()
        HistoryButton.Text = "→ HISTORY"
        wait(0.3)
        HistoryPanel.Visible = false
    end
end

function updateHistoryList()
    for _, child in pairs(HistoryScrollFrame:GetChildren()) do
        if child.Name == "HistoryItem" then child:Destroy() end
    end
    NoHistoryLabel.Visible = #downloadHistory == 0
    if #downloadHistory == 0 then
        HistoryScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
        return
    end
    local itemHeight = 45
    local spacing = 5
    local totalHeight = 0
    for i, entry in ipairs(downloadHistory) do
        local currentEntry = {url = entry.url, fileName = entry.fileName, date = entry.date}
        local currentIndex = i
        local historyItem = Instance.new("Frame")
        historyItem.Name = "HistoryItem"
        historyItem.Size = UDim2.new(1, -10, 0, itemHeight)
        historyItem.Position = UDim2.new(0, 5, 0, totalHeight)
        historyItem.BackgroundColor3 = i % 2 == 0 and Color3.fromRGB(55, 55, 55) or Color3.fromRGB(50, 50, 50)
        historyItem.BorderSizePixel = 0
        historyItem.Parent = HistoryScrollFrame
        local itemCorner = Instance.new("UICorner")
        itemCorner.CornerRadius = UDim.new(0, 4)
        itemCorner.Parent = historyItem
        local fileNameLabel = Instance.new("TextLabel")
        fileNameLabel.Size = UDim2.new(0.6, -5, 0, 20)
        fileNameLabel.Position = UDim2.new(0, 5, 0, 5)
        fileNameLabel.BackgroundTransparency = 1
        fileNameLabel.Text = currentEntry.fileName or "Unknown"
        fileNameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        fileNameLabel.Font = Enum.Font.Gotham
        fileNameLabel.TextSize = 11
        fileNameLabel.TextTruncate = Enum.TextTruncate.AtEnd
        fileNameLabel.Parent = historyItem
        local dateLabel = Instance.new("TextLabel")
        dateLabel.Size = UDim2.new(0.6, -5, 0, 15)
        dateLabel.Position = UDim2.new(0, 5, 0, 25)
        dateLabel.BackgroundTransparency = 1
        dateLabel.Text = currentEntry.date or "Unknown date"
        dateLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
        dateLabel.Font = Enum.Font.Gotham
        dateLabel.TextSize = 9
        dateLabel.Parent = historyItem
        local playHistoryButton = Instance.new("TextButton")
        playHistoryButton.Size = UDim2.new(0.15, -5, 0, 25)
        playHistoryButton.Position = UDim2.new(0.6, 5, 0, 10)
        playHistoryButton.BackgroundColor3 = Color3.fromRGB(70, 150, 70)
        playHistoryButton.BorderSizePixel = 0
        playHistoryButton.Text = "▶"
        playHistoryButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        playHistoryButton.Font = Enum.Font.GothamBold
        playHistoryButton.TextSize = 12
        playHistoryButton.Parent = historyItem
        local playButtonCorner = Instance.new("UICorner")
        playButtonCorner.CornerRadius = UDim.new(0, 4)
        playButtonCorner.Parent = playHistoryButton
        local deleteHistoryButton = Instance.new("TextButton")
        deleteHistoryButton.Size = UDim2.new(0.15, -5, 0, 25)
        deleteHistoryButton.Position = UDim2.new(0.8, 10, 0, 10)
        deleteHistoryButton.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
        deleteHistoryButton.BorderSizePixel = 0
        deleteHistoryButton.Text = "🗑️"
        deleteHistoryButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        deleteHistoryButton.Font = Enum.Font.Gotham
        deleteHistoryButton.TextSize = 12
        deleteHistoryButton.Parent = historyItem
        local deleteButtonCorner = Instance.new("UICorner")
        deleteButtonCorner.CornerRadius = UDim.new(0, 4)
        deleteButtonCorner.Parent = deleteHistoryButton
        playHistoryButton.MouseButton1Click:Connect(function()
            if currentEntry and currentEntry.url then
                StatusLabel.Text = "⏬ Loading from history..."
                StatusLabel.TextColor3 = Color3.fromRGB(100, 200, 255)
                if isHistoryOpen then toggleHistoryPanel() end
                playMusicFromUrl(currentEntry.url, currentEntry.fileName or "audio.mp3")
            end
        end)
        deleteHistoryButton.MouseButton1Click:Connect(function()
            if removeFromHistory(currentIndex) then
                StatusLabel.Text = "🗑️ Removed from history"
                StatusLabel.TextColor3 = Color3.fromRGB(255, 150, 150)
                updateHistoryList()
            end
        end)
        totalHeight = totalHeight + itemHeight + spacing
    end
    HistoryScrollFrame.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
end

-- ========== EVENT CONNECTIONS ==========

SpeedTextBox.FocusLost:Connect(function(enterPressed)
    applySpeedFromTextBox()
end)

SpeedUpButton.MouseButton1Click:Connect(function()
    local newSpeed = math.min(currentSpeed + 0.25, 100)
    updateSpeed(newSpeed)
end)

SpeedDownButton.MouseButton1Click:Connect(function()
    local newSpeed = math.max(currentSpeed - 0.25, 0)
    updateSpeed(newSpeed)
end)

local dragInput, dragStart, startPos
local function update(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragStart = nil
            end
        end)
    end
end)

MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragStart then update(input) end
end)

VolumeSlider.MouseButton1Down:Connect(function()
    local connection
    connection = RunService.Heartbeat:Connect(function()
        local mouseX = mouse.X - VolumeSlider.AbsolutePosition.X
        local volume = math.clamp(mouseX / VolumeSlider.AbsoluteSize.X, 0, 1)
        updateVolumeSlider(volume)
    end)
    VolumeSlider.MouseButton1Up:Connect(function() connection:Disconnect() end)
    VolumeSlider.MouseLeave:Connect(function() connection:Disconnect() end)
end)

VolumeSlider.MouseButton1Click:Connect(function()
    local mouseX = mouse.X - VolumeSlider.AbsolutePosition.X
    local volume = math.clamp(mouseX / VolumeSlider.AbsoluteSize.X, 0, 1)
    updateVolumeSlider(volume)
end)

CloseButton.MouseButton1Click:Connect(function()
    if isMuted then muteAllGameSounds(false) end
    stopMusic()
    ScreenGui:Destroy()
end)

MinimizeButton.MouseButton1Click:Connect(function()
    if isMinimized then
        MainFrame.Size = originalSize
        ContentFrame.Visible = true
        OutlineFrame.Visible = true
        isMinimized = false
    else
        if isSearchOpen then isSearchOpen = false; SearchPanel.Visible = false end
        if isInfoOpen then isInfoOpen = false; InfoPanel.Visible = false end
        MainFrame.Size = minimizedSize
        ContentFrame.Visible = false
        OutlineFrame.Visible = false
        isMinimized = true
    end
end)

InfoButton.MouseButton1Click:Connect(function() toggleInfoPanel() end)
SearchButton.MouseButton1Click:Connect(function() toggleSearchPanel() end)

SearchPanelButton.MouseButton1Click:Connect(function()
    local searchTerm = SearchTextBox.Text
    searchMusic(searchTerm)
end)

SearchTextBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local searchTerm = SearchTextBox.Text
        searchMusic(searchTerm)
    end
end)

HistoryButton.MouseButton1Click:Connect(function() toggleHistoryPanel() end)
BackButton.MouseButton1Click:Connect(function() toggleHistoryPanel() end)

MuteToggle.MouseButton1Click:Connect(function() muteAllGameSounds(not isMuted) end)

LoopToggle.MouseButton1Click:Connect(function()
    isLooping = not isLooping
    if isLooping then
        LoopToggle.BackgroundColor3 = Color3.fromRGB(80, 130, 200)
        LoopToggle.Text = "🔁 LOOP: ON"
        if currentSound then currentSound.Looped = true end
    else
        LoopToggle.BackgroundColor3 = Color3.fromRGB(130, 130, 130)
        LoopToggle.Text = "➡ LOOP: OFF"
        if currentSound then currentSound.Looped = false end
    end
end)

PlayButton.MouseButton1Click:Connect(function()
    local url = UrlTextBox.Text
    if url == "" then
        StatusLabel.Text = "❌ Error: Please enter URL"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    if string.sub(string.lower(url), -4) ~= ".mp3" then
        StatusLabel.Text = "❌ Error: URL must end with .mp3"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    local fileName = "audio.mp3"
    local urlParts = string.split(url, "/")
    if #urlParts > 0 then
        local lastPart = urlParts[#urlParts]
        if string.find(lastPart, ".mp3") then
            fileName = lastPart
            fileName = string.gsub(fileName, "%%20", " ")
            fileName = string.gsub(fileName, "%%25", "%%")
        end
    end
    playMusicFromUrl(url, fileName)
end)

PauseButton.MouseButton1Click:Connect(function()
    if not currentSound then
        StatusLabel.Text = "❌ No music playing"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    togglePause()
end)

StopButton.MouseButton1Click:Connect(function()
    stopMusic()
    if PauseButton then PauseButton.Text = "⏸ PAUSE" end
    StatusLabel.Text = "⏹ Music Stopped"
    StatusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
end)

-- ========== INITIALIZATION ==========

updateVolumeSlider(currentVolume)
updateSpeed(currentSpeed)
downloadHistory = loadHistory()
updateHistoryList()

local function onCharacterAdded(character)
    if currentSound and isPlaying then
        currentSound.Parent = workspace
        if not currentSound.IsPlaying then currentSound:Play() end
    end
end
player.CharacterAdded:Connect(onCharacterAdded)

Players.PlayerRemoving:Connect(function(leavingPlayer)
    if leavingPlayer == player then
        if isMuted then muteAllGameSounds(false) end
        stopMusic()
        ScreenGui:Destroy()
    end
end)
