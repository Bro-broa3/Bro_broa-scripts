-- Roblox Exploit MP3 Player GUI - Ultimate Mute, Info Button, All Features
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local HttpService = game:GetService("HttpService")
local SoundService = game:GetService("SoundService")

local player = Players.LocalPlayer
local mouse = player:GetMouse()

-- ========== VARIABLES ==========
local currentSound = nil
local isMuted = false
local isLooping = true
local currentVolume = 1.0
local currentSpeed = 1.0
local isMinimized = false
local isHistoryOpen = false
local isSearchOpen = false
local isInfoOpen = false
local downloadHistory = {}
local isPlaying = false
local isPaused = false
local pausedTimePosition = 0
local HISTORY_FILE = "mp3_history.json"

local originalSoundVolumes = {}
local originalSoundGroupVolumes = {}
local originalSoundServiceMuted = false

-- ========== CORE FUNCTIONS ==========

local function loadHistory()
    local success, result = pcall(function()
        if readfile and isfile and isfile(HISTORY_FILE) then
            local jsonData = readfile(HISTORY_FILE)
            return HttpService:JSONDecode(jsonData)
        end
    end)
    return success and result or {}
end

local function saveHistory()
    local success, errorMsg = pcall(function()
        if writefile then
            local jsonData = HttpService:JSONEncode(downloadHistory)
            writefile(HISTORY_FILE, jsonData)
        end
    end)
    if not success then
        warn("Failed to save history: " .. tostring(errorMsg))
    end
end

local function addToHistory(url, fileName)
    local historyEntry = {
        url = url,
        fileName = fileName,
        timestamp = os.time(),
        date = os.date("%Y-%m-%d %H:%M:%S")
    }
    table.insert(downloadHistory, 1, historyEntry)
    if #downloadHistory > 50 then
        for i = 51, #downloadHistory do
            downloadHistory[i] = nil
        end
    end
    saveHistory()
end

local function removeFromHistory(index)
    if downloadHistory[index] then
        table.remove(downloadHistory, index)
        saveHistory()
        return true
    end
    return false
end

local function stopMusic()
    if currentSound then
        currentSound:Stop()
        wait(0.1)
        currentSound:Destroy()
        currentSound = nil
    end
    isPlaying = false
    isPaused = false
    pausedTimePosition = 0
end

local function muteAllGameSounds(mute)
    isMuted = mute
    
    pcall(function()
        SoundService.RespectFilteringEnabled = false
        if mute then
            originalSoundServiceMuted = SoundService.Muted
            SoundService.Muted = true
        else
            SoundService.Muted = originalSoundServiceMuted
        end
    end)
    
    local allServices = {
        game, workspace,
        game:GetService("Lighting"),
        game:GetService("ReplicatedStorage"),
        game:GetService("ReplicatedFirst"),
        game:GetService("ServerStorage"),
        game:GetService("ServerScriptService"),
        game:GetService("StarterGui"),
        game:GetService("StarterPack"),
        game:GetService("StarterPlayer"),
        game:GetService("StarterCharacterScripts"),
        game:GetService("SoundService"),
        game:GetService("Players"),
        game:GetService("Chat"),
        game:GetService("TeleportService")
    }
    
    if player then
        if player.Character then table.insert(allServices, player.Character) end
        if player.Backpack then table.insert(allServices, player.Backpack) end
        if player.PlayerGui then table.insert(allServices, player.PlayerGui) end
        if player.PlayerScripts then table.insert(allServices, player.PlayerScripts) end
    end
    
    pcall(function()
        if workspace.CurrentCamera then
            table.insert(allServices, workspace.CurrentCamera)
        end
    end)
    
    for _, container in ipairs(allServices) do
        pcall(function()
            if container then
                for _, obj in pairs(container:GetDescendants()) do
                    if obj:IsA("Sound") then
                        if mute then
                            if originalSoundVolumes[obj] == nil then
                                originalSoundVolumes[obj] = obj.Volume
                            end
                            obj.Volume = 0
                        else
                            local origVol = originalSoundVolumes[obj]
                            if origVol ~= nil then
                                obj.Volume = origVol
                                originalSoundVolumes[obj] = nil
                            end
                        end
                    elseif obj:IsA("SoundGroup") then
                        if mute then
                            if originalSoundGroupVolumes[obj] == nil then
                                originalSoundGroupVolumes[obj] = obj.Volume
                            end
                            obj.Volume = 0
                        else
                            local origVol = originalSoundGroupVolumes[obj]
                            if origVol ~= nil then
                                obj.Volume = origVol
                                originalSoundGroupVolumes[obj] = nil
                            end
                        end
                    end
                end
            end
        end)
    end
    
    if currentSound then
        pcall(function()
            currentSound.Volume = mute and 0 or currentVolume
        end)
    end
    
    if not mute then
        originalSoundVolumes = {}
        originalSoundGroupVolumes = {}
    end
    
    if MuteToggle then
        if mute then
            MuteToggle.BackgroundColor3 = Color3.fromRGB(80, 180, 80)
            MuteToggle.Text = "🔇 GAME MUTE: ON"
        else
            MuteToggle.BackgroundColor3 = Color3.fromRGB(180, 80, 80)
            MuteToggle.Text = "🔊 GAME MUTE: OFF"
        end
    end
    
    if StatusLabel then
        if mute then
            StatusLabel.Text = "🔇 All game sounds muted"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        else
            StatusLabel.Text = "🔊 All game sounds unmuted"
            StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        end
    end
end

local function updateVolumeSlider(volume)
    currentVolume = volume
    if VolumeFill then
        VolumeFill.Size = UDim2.new(volume, 0, 1, 0)
    end
    if VolumeLabel then
        VolumeLabel.Text = "Volume: " .. math.floor(volume * 100) .. "%"
    end
    if currentSound and not isMuted then
        currentSound.Volume = volume
    end
end

local function updateSpeed(speed)
    currentSpeed = speed
    if SpeedTextBox then
        SpeedTextBox.Text = string.format("%.2f", speed) .. "x"
    end
    if SpeedLabel then
        SpeedLabel.Text = "Speed: " .. string.format("%.2f", speed) .. "x"
    end
    if currentSound then
        currentSound.PlaybackSpeed = speed
    end
end

local function togglePause()
    if not currentSound then return end
    if isPaused then
        currentSound.TimePosition = pausedTimePosition
        currentSound:Resume()
        isPaused = false
        isPlaying = true
        if PauseButton then PauseButton.Text = "⏸ PAUSE" end
        if StatusLabel then
            StatusLabel.Text = "▶ Resumed"
            StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        end
    else
        pausedTimePosition = currentSound.TimePosition
        currentSound:Pause()
        isPaused = true
        isPlaying = false
        if PauseButton then PauseButton.Text = "▶ RESUME" end
        if StatusLabel then
            StatusLabel.Text = "⏸ Paused"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
        end
    end
end

local function playMusicFromUrl(url, fileName)
    stopMusic()
    if StatusLabel then
        StatusLabel.Text = "⏬ Downloading..."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    end
    local timestamp = os.time()
    local uniqueFileName = "audio_" .. timestamp .. ".mp3"
    local success, errorMessage = pcall(function()
        local audioData = game:HttpGet(url)
        writefile(uniqueFileName, audioData)
        currentSound = Instance.new("Sound")
        currentSound.SoundId = getcustomasset(uniqueFileName)
        currentSound.Volume = isMuted and 0 or currentVolume
        currentSound.Looped = isLooping
        currentSound.PlaybackSpeed = currentSpeed
        currentSound.Parent = workspace
        currentSound:Play()
        isPlaying = true
        isPaused = false
        pausedTimePosition = 0
        if PauseButton then PauseButton.Text = "⏸ PAUSE" end
        pcall(function()
            if listfiles then
                local files = listfiles()
                local audioFiles = {}
                for _, file in ipairs(files) do
                    if string.find(file, "audio_") and string.find(file, ".mp3") then
                        table.insert(audioFiles, file)
                    end
                end
                table.sort(audioFiles, function(a, b) return a > b end)
                for i = 11, #audioFiles do
                    delfile(audioFiles[i])
                end
            end
        end)
        local alreadyInHistory = false
        for _, entry in ipairs(downloadHistory) do
            if entry.url == url then
                alreadyInHistory = true
                break
            end
        end
        if not alreadyInHistory then
            addToHistory(url, fileName)
        end
    end)
    if success and currentSound then
        if StatusLabel then
            StatusLabel.Text = "🎵 Now Playing: " .. (fileName or "Unknown")
            StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        end
        return true
    else
        if StatusLabel then
            StatusLabel.Text = "❌ Error: " .. tostring(errorMessage)
            StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
        stopMusic()
        return false
    end
end

